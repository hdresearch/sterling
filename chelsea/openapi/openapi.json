{
  "openapi": "3.1.0",
  "info": {
    "title": "chelsea_server2",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/system/health": {
      "get": {
        "tags": [],
        "summary": "Health check endpoint",
        "operationId": "health_handler",
        "responses": {
          "200": {
            "description": "Health check successful",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/system/telemetry": {
      "get": {
        "tags": [],
        "summary": "Telemetry endpoint (return type to be filled in)",
        "operationId": "telemetry_handler",
        "responses": {
          "200": {
            "description": "Telemetry information returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemTelemetryResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error while retrieving system info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChelseaServerError"
                }
              }
            }
          }
        }
      }
    },
    "/api/system/version": {
      "get": {
        "tags": [],
        "summary": "Version endpoint",
        "operationId": "version_handler",
        "responses": {
          "200": {
            "description": "Current build version information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChelseaVersion"
                }
              }
            }
          },
          "500": {
            "description": "Internal error while retrieving version info",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/vm": {
      "get": {
        "tags": [],
        "summary": "List all VMs",
        "operationId": "vm_list_all_handler",
        "responses": {
          "200": {
            "description": "Successfully retrieved all VMs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmListAllResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/commit_all": {
      "post": {
        "tags": [],
        "summary": "Commit the current state of all VMs",
        "operationId": "vm_commit_all_handler",
        "parameters": [
          {
            "name": "keep_paused",
            "in": "query",
            "description": "If true, keep all VMs paused after committing",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If true, request will immediately fail if any VM is not finished booting. Defaults to false (do wait).",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully committed all VM states",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommitManyResult"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/commit_many": {
      "post": {
        "tags": [],
        "summary": "Commit the current state of many VMs by IDs",
        "operationId": "vm_commit_many_handler",
        "parameters": [
          {
            "name": "keep_paused",
            "in": "query",
            "description": "If true, keep all selected VMs paused after committing",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If true, request will immediately fail if any selected VM is not finished booting. Defaults to false (do wait).",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "description": "A list of VM IDs (v4 UUIDs) to commit",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmCommitManyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully committed multiple VM states",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommitManyResult"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/from_commit": {
      "post": {
        "tags": [],
        "summary": "Create a new VM from a commit",
        "operationId": "vm_from_commit_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmFromCommitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully created VM from commit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmFromCommitResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/new": {
      "post": {
        "tags": [],
        "summary": "Create a new VM",
        "operationId": "vm_create_handler",
        "parameters": [
          {
            "name": "wait_boot",
            "in": "query",
            "description": "If true, wait for the VM to finish booting before returning",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully created new root VM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmCreateResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}": {
      "get": {
        "tags": [],
        "summary": "Get the status of a VM",
        "operationId": "vm_status_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) whose status to fetch",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully fetched VM status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmSummary"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "tags": [],
        "summary": "Delete a VM",
        "description": "Delete the specified VM.",
        "operationId": "vm_delete_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to delete",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If true, return an error immediately if the VM is still booting. Default: false.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully deleted VM"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}/commit": {
      "post": {
        "tags": [],
        "summary": "Commit the current state of a VM",
        "operationId": "vm_commit_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to commit",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keep_paused",
            "in": "query",
            "description": "If set to true, the VM will remain paused after commit",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If true, return an error immediately if the VM is still booting. Default: false.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "description": "The commit ID to use for commit file uploads, etc.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmCommitRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully committed VM state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmCommitResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}/sleep": {
      "post": {
        "tags": [],
        "summary": "Put a VM to sleep. This snapshots the VM, then kills the associated process, allowing it to be later resumed via the wake command.",
        "operationId": "vm_sleep_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to put to sleep",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If set to true, error immediately rather than waiting for a booting VM (default: false)",
            "required": true,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "VM successfully put to sleep"
          },
          "404": {
            "description": "VM not found"
          },
          "409": {
            "description": "VM cannot be put to sleep from current state"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}/ssh_key": {
      "get": {
        "tags": [],
        "summary": "Get the SSH public key for a VM",
        "operationId": "vm_get_ssh_key_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to retrieve the SSH key for",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved VM SSH public key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VmSshKeyResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}/state": {
      "patch": {
        "tags": [],
        "summary": "Update the state of a VM",
        "operationId": "vm_update_state_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to update",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip_wait_boot",
            "in": "query",
            "description": "If true, return an error immediately if the VM is still booting. Defaults to false.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmUpdateStateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully updated VM state"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/vm/{vm_id}/wake": {
      "post": {
        "tags": [],
        "summary": "Wake a sleeping VM. This starts a VM from the temporary snapshot associated with it, then deletes that snapshot.",
        "operationId": "vm_wake_handler",
        "parameters": [
          {
            "name": "vm_id",
            "in": "path",
            "description": "The VM ID (v4 UUID) to wake",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VmWakeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "VM successfully woken"
          },
          "404": {
            "description": "VM not found"
          },
          "409": {
            "description": "VM cannot be woken from current state"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChelseaServerError": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "ChelseaVersion": {
        "type": "object",
        "description": "Response struct for GET /api/system/version",
        "required": [
          "executable_name",
          "workspace_version",
          "git_hash",
          "jailer_version",
          "firecracker_version",
          "ceph_client_version",
          "ceph_cluster_version"
        ],
        "properties": {
          "ceph_client_version": {
            "type": "string",
            "description": "Ceph client executable version"
          },
          "ceph_cluster_version": {
            "type": "string",
            "description": "Ceph version reported by cluster"
          },
          "executable_name": {
            "type": "string",
            "description": "Executable identifier; should be \"chelsea\""
          },
          "firecracker_version": {
            "type": "string",
            "description": "Firecracker executable version"
          },
          "git_hash": {
            "type": "string",
            "description": "Current git hash used for the build"
          },
          "jailer_version": {
            "type": "string",
            "description": "Jailer executable version"
          },
          "workspace_version": {
            "type": "string",
            "description": "Current workspace version"
          }
        }
      },
      "CommitManyFailure": {
        "type": "object",
        "description": "Represents a failed VM commit mapping VM ID to error.",
        "required": [
          "vm_id",
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "vm_id": {
            "type": "string"
          }
        }
      },
      "CommitManyResult": {
        "type": "object",
        "description": "Contains a mapping of VM IDs to their commit IDs, if successful, or error messages, if failed.",
        "required": [
          "succeeded",
          "failed",
          "host_architecture"
        ],
        "properties": {
          "failed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommitManyFailure"
            }
          },
          "host_architecture": {
            "type": "string",
            "description": "The CPU architecture of the original host machine"
          },
          "succeeded": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CommitManySuccess"
            }
          }
        }
      },
      "CommitManySuccess": {
        "type": "object",
        "description": "Represents a successful VM commit mapping VM ID to commit ID",
        "required": [
          "vm_id",
          "commit_id"
        ],
        "properties": {
          "commit_id": {
            "type": "string"
          },
          "vm_id": {
            "type": "string"
          }
        }
      },
      "SystemTelemetryResponse": {
        "type": "object",
        "description": "The response body for GET /api/system/telemetry",
        "required": [
          "ram",
          "cpu",
          "fs",
          "chelsea"
        ],
        "properties": {
          "chelsea": {
            "$ref": "#/components/schemas/TelemetryChelsea"
          },
          "cpu": {
            "$ref": "#/components/schemas/TelemetryCpu"
          },
          "fs": {
            "$ref": "#/components/schemas/TelemetryFs"
          },
          "ram": {
            "$ref": "#/components/schemas/TelemetryRam"
          }
        }
      },
      "TelemetryChelsea": {
        "type": "object",
        "description": "Represents chelsea-specific stats",
        "required": [
          "vm_count_max",
          "vm_count_current"
        ],
        "properties": {
          "vm_count_current": {
            "type": "integer",
            "format": "int64",
            "description": "The number of VMs currently allocated on this node",
            "minimum": 0
          },
          "vm_count_max": {
            "type": "integer",
            "format": "int64",
            "description": "The maximum number of VMs this node can support; currently tied to the number of VmNetworks allocated by the NetworkManager",
            "minimum": 0
          }
        }
      },
      "TelemetryCpu": {
        "type": "object",
        "description": "The system's CPU totals/usage; all units are percentages, ie: 35.32 = 35.32%, or vCPU counts (for VMs)\nfor consistency",
        "required": [
          "real_total",
          "real_available",
          "vcpu_count_total",
          "vcpu_count_vm_total",
          "vcpu_count_vm_available"
        ],
        "properties": {
          "real_available": {
            "type": "number",
            "format": "double",
            "description": "The %CPU stated by the system to be available"
          },
          "real_total": {
            "type": "number",
            "format": "double",
            "description": "The total %CPU available on the system (likely 100.00%)"
          },
          "vcpu_count_total": {
            "type": "integer",
            "format": "int64",
            "description": "The total vCPU count",
            "minimum": 0
          },
          "vcpu_count_vm_available": {
            "type": "integer",
            "format": "int64",
            "description": "The total, minus theoretical vCPU consumption of VMs",
            "minimum": 0
          },
          "vcpu_count_vm_total": {
            "type": "integer",
            "format": "int64",
            "description": "The vCPU count \"reserved\" for VMs",
            "minimum": 0
          }
        }
      },
      "TelemetryFs": {
        "type": "object",
        "description": "The system's FS totals/usage; all units are MiB",
        "required": [
          "mib_total",
          "mib_available"
        ],
        "properties": {
          "mib_available": {
            "type": "integer",
            "format": "int64",
            "description": "The available FS space available to the system",
            "minimum": 0
          },
          "mib_total": {
            "type": "integer",
            "format": "int64",
            "description": "The total FS space available to the system",
            "minimum": 0
          }
        }
      },
      "TelemetryRam": {
        "type": "object",
        "description": "The system's RAM totals/usage; all units are MiB",
        "required": [
          "real_mib_total",
          "real_mib_available",
          "vm_mib_total",
          "vm_mib_available"
        ],
        "properties": {
          "real_mib_available": {
            "type": "integer",
            "format": "int64",
            "description": "The amount of RAM stated by the system to be available",
            "minimum": 0
          },
          "real_mib_total": {
            "type": "integer",
            "format": "int64",
            "description": "The total amount of RAM available on the system",
            "minimum": 0
          },
          "vm_mib_available": {
            "type": "integer",
            "format": "int64",
            "description": "The total, minus theoretical RAM consumption of VMs",
            "minimum": 0
          },
          "vm_mib_total": {
            "type": "integer",
            "format": "int64",
            "description": "The total amount of RAM \"reserved\" for VMs",
            "minimum": 0
          }
        }
      },
      "VmCommitIdPair": {
        "type": "object",
        "description": "A VM ID + Commit ID pair",
        "required": [
          "vm_id",
          "commit_id"
        ],
        "properties": {
          "commit_id": {
            "type": "string",
            "format": "uuid"
          },
          "vm_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "VmCommitManyRequest": {
        "type": "object",
        "description": "Request body for POST /api/vm/commit_many",
        "required": [
          "requests"
        ],
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VmCommitIdPair"
            }
          }
        }
      },
      "VmCommitRequest": {
        "type": "object",
        "description": "The request body for POST /api/vm/{vm_id}/commit",
        "properties": {
          "commit_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid",
            "description": "If provided, chelsea will use the requested commit UUID. Otherwise, it will generate a UUID itself."
          }
        }
      },
      "VmCommitResponse": {
        "type": "object",
        "description": "The response body for POST /api/vm/{vm_id}/commit",
        "required": [
          "commit_id"
        ],
        "properties": {
          "commit_id": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the newly-created commit"
          }
        }
      },
      "VmCreateRequest": {
        "type": "object",
        "description": "Request body for POST /api/vm/new",
        "required": [
          "vm_config",
          "wireguard"
        ],
        "properties": {
          "vm_config": {
            "$ref": "#/components/schemas/VmCreateVmConfig"
          },
          "vm_id": {
            "type": [
              "string",
              "null"
            ],
            "format": "uuid",
            "description": "The UUID to be assigned to the newly-created VM; if none is supplied, chelsea will generate one."
          },
          "wireguard": {
            "$ref": "#/components/schemas/VmWireGuardConfig",
            "description": "Optional WireGuard configuration. If None, VM will not have WireGuard setup."
          }
        }
      },
      "VmCreateResponse": {
        "type": "object",
        "description": "Response body for POST /api/vm/new",
        "required": [
          "vm_id"
        ],
        "properties": {
          "vm_id": {
            "type": "string",
            "format": "uuid",
            "description": "The UUID of the newly-created VM."
          }
        }
      },
      "VmCreateVmConfig": {
        "type": "object",
        "description": "Struct representing configuration options common to all VMs",
        "properties": {
          "fs_size_mib": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "The disk size, in MiB.",
            "minimum": 0
          },
          "image_name": {
            "type": [
              "string",
              "null"
            ],
            "description": "The filesystem base image name. Currently, must be 'default'"
          },
          "kernel_name": {
            "type": [
              "string",
              "null"
            ],
            "description": "The kernel name. Currently, must be 'default.bin'"
          },
          "mem_size_mib": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
