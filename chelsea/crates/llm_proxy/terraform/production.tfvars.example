environment = "production"

# ── Networking (fill in from your AWS account) ────────────────────────────────
vpc_id             = "vpc-XXXXXXXXX"
private_subnet_ids = ["subnet-aaa", "subnet-bbb"]   # Private subnets (with NAT gateway)
public_subnet_ids  = ["subnet-ccc", "subnet-ddd"]   # For ALB (≥2 AZs)

# If you already have an internal.vers.sh private hosted zone, set its ID here.
# Leave empty to create one automatically.
internal_zone_id = ""
internal_domain  = "tokens.internal.vers.sh"

# RDS security group — we'll add an ingress rule so Fargate tasks can reach Postgres.
database_security_group_id = "sg-XXXXXXXXX"

# ── Logs Database ─────────────────────────────────────────────────────────────
logs_db_instance_class        = "db.t4g.medium"   # ~$50/mo
logs_db_allocated_storage     = 20                 # GB, autoscales up
logs_db_max_allocated_storage = 100                # GB ceiling

# ── Service sizing ────────────────────────────────────────────────────────────
cpu           = 512   # 0.5 vCPU
memory        = 1024  # 1 GB
desired_count = 2

image_tag = "latest"

# ── GitHub Actions OIDC ───────────────────────────────────────────────────────
github_repo = "hdresearch/chelsea"
