diff --git a/src/vmm/src/prefault.rs b/src/vmm/src/prefault.rs
new file mode 100644
index 000000000..c1f51510c
--- /dev/null
+++ b/src/vmm/src/prefault.rs
@@ -0,0 +1,72 @@
+// Copyright Amazon.com, Inc. or its affiliates.
+// SPDX-License-Identifier: Apache-2.0
+//
+// Eager guest-RAM prefault helper.
+// Use MADV_POPULATE_READ when available (Linux >= 5.14), else fall back to a page-touch loop.
+//
+// Call this after snapshot restore maps GuestMemoryMmap, and before starting vCPUs.
+
+use std::io;
+use vm_memory::{guest_memory::MemoryRegionAddress, GuestMemory, GuestMemoryRegion};
+use crate::vstate::memory::GuestRegionMmap;
+use crate::utils::get_page_size;
+
+#[cfg(target_os = "linux")]
+fn try_madvise_populate(addr: *mut u8, len: usize) -> io::Result<()> {
+    // Safety: addr/len describe a valid, process-owned mapping. We only advise.
+    let rc = unsafe {
+        libc::madvise(
+            addr as *mut libc::c_void,
+            len,
+            libc::MADV_POPULATE_READ as libc::c_int,
+        )
+    };
+    if rc == 0 {
+        Ok(())
+    } else {
+        Err(io::Error::last_os_error())
+    }
+}
+
+#[cfg(not(target_os = "linux"))]
+fn try_madvise_populate(_addr: *mut u8, _len: usize) -> io::Result<()> {
+    Err(io::Error::new(
+        io::ErrorKind::Unsupported,
+        "MADV_POPULATE_READ unsupported on this OS",
+    ))
+}
+
+fn prefault_range(start: *mut u8, len: usize) -> io::Result<()> {
+    if try_madvise_populate(start, len).is_err() {
+        let page = get_page_size().unwrap();
+        let mut off = 0usize;
+        while off < len {
+            unsafe { std::ptr::read_volatile(start.add(off)); }
+            off = off.saturating_add(page);
+        }
+    }
+    Ok(())
+}
+
+/// Prefault using any GuestMemory implementation (e.g., GuestMemoryMmap).
+pub fn prefault_guest_memory<M: GuestMemory>(mem: &M) -> io::Result<()> {
+    for region in mem.iter() {
+        let host = region
+            .get_host_address(MemoryRegionAddress(0))
+            .map_err(|e| io::Error::new(io::ErrorKind::Other, format!("host addr: {e}")))?;
+        prefault_range(host, region.len().try_into().unwrap())?;
+    }
+    Ok(())
+}
+
+/// Prefault using a vector of GuestRegionMmap instances.
+pub fn prefault_guest_regions(regions: &Vec<GuestRegionMmap>) -> io::Result<()> {
+    for region in regions {
+        let host = region
+            .get_host_address(MemoryRegionAddress(0))
+            .map_err(|e| io::Error::new(io::ErrorKind::Other, format!("host addr: {e}")))?;
+        prefault_range(host, region.len().try_into().unwrap())?;
+    }
+    Ok(())
+}
+
