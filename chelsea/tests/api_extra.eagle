###############################################################################
#
# api_extra.eagle --
#
# This file contains additional end-to-end integration tests for API
# endpoints and error cases that are not covered by main.eagle.  These
# tests cover: internal VM listing, SSH key retrieval (internal and
# public), network info validation, VM state after creation, and error
# cases for operations on non-existent VMs.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

catch {info previouspid true}

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file that do not
#       require any plugins to be loaded.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################

if {[info exists wireGuardFile] && \
    [hasRuntimeOption remoteChelsea]} then {
  writeFile $wireGuardFile ""; # TODO: Fix me.
  wgQuickUp $test_channel $wireGuardFile
}

###############################################################################
#
# chelsea-400.0 — list VMs via internal API, verify created VM appears
#
###############################################################################

runTest {test chelsea-400.0 {list VMs via internal API} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set vmList [internal_listVm]

  #
  # NOTE: The newly created VM should appear in the list.
  #
  set found false

  foreach vmId $vmList {
    if {$vmId eq $ids(1)} then {
      set found true; break
    }
  }

  internal_deleteVm id $ids(1)

  if {!$found} then {
    error [appendArgs \
        "created VM " $ids(1) " not found in list: " $vmList]
  }

  list true
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids vmList found vmId
} -constraints $commonConstraints -result {true}}

###############################################################################
#
# chelsea-401.0 — retrieve SSH key via internal API
#
###############################################################################

runTest {test chelsea-401.0 {retrieve SSH key via internal API} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set sshInfo [internal_sshKey id $ids(1)]

  set port [getDictionaryValue $sshInfo port]
  set privateKey [getDictionaryValue $sshInfo privateKey]

  if {![isValidPort $port]} then {
    error [appendArgs "invalid SSH port: " $port]
  }

  if {![stringIsSshPrivateKey $privateKey]} then {
    error "invalid SSH private key format"
  }

  internal_deleteVm id $ids(1)

  list true
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids sshInfo port privateKey
} -constraints $commonConstraints -result {true}}

###############################################################################
#
# chelsea-402.0 — retrieve network info via internal API
#
###############################################################################

runTest {test chelsea-402.0 {retrieve network info via internal API} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set netJson [internal_network id $ids(1)]

  #
  # NOTE: Verify the network JSON contains a valid IPv4 address.
  #
  set vmIp [jqRawString $netJson .vm_ipv4]

  if {![string is inetaddr -strict $vmIp]} then {
    error [appendArgs "invalid VM IPv4 address: " $vmIp]
  }

  internal_deleteVm id $ids(1)

  list true
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids netJson vmIp
} -constraints $commonConstraints -result {true}}

###############################################################################
#
# chelsea-403.0 — VM state is running after creation
#
###############################################################################

runTest {test chelsea-403.0 {VM state is running after creation} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set state [internal_getVmState id $ids(1)]

  internal_deleteVm id $ids(1)

  set state
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids state
} -constraints $commonConstraints -result {running}}

###############################################################################
#
# chelsea-404.0 — delete non-existent VM returns error
#
###############################################################################

runTest {test chelsea-404.0 {delete non-existent VM returns error} -body {
  set fakeId [guid new]

  set code [catch {internal_deleteVm id $fakeId} result]

  list $code [expr {$code != 0}]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain fakeId code result
} -constraints $commonConstraints -result {1 True}}

###############################################################################
#
# chelsea-405.0 — get state of non-existent VM returns error
#
###############################################################################

runTest {test chelsea-405.0 {get state of non-existent VM returns error} -body {
  set fakeId [guid new]

  set code [catch {internal_getVmState id $fakeId} result]

  list $code [expr {$code != 0}]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain fakeId code result
} -constraints $commonConstraints -result {1 True}}

###############################################################################
#
# chelsea-406.0 — telemetry response has expected nested structure
#
###############################################################################

runTest {test chelsea-406.0 {telemetry response has nested structure} -body {
  set json [internal_telemetry]

  #
  # NOTE: Verify the JSON has the expected top-level sections:
  #       ram, cpu, fs, and chelsea.
  #
  set sections [list]

  foreach section [list ram cpu fs chelsea] {
    set value [jq $json [appendArgs . $section]]

    if {$value ne "null"} then {
      lappend sections $section
    }
  }

  join $sections " "
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain json sections section value
} -constraints $commonConstraints -result {ram cpu fs chelsea}}

###############################################################################
#
# chelsea-407.x — retrieve SSH key via public API (with proxy variants)
#
###############################################################################

foreach proxy [list 0 1] {
  runTest [string map [list %proxy% $proxy] \
      {test chelsea-407.%proxy% {retrieve SSH key via public API} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set sshInfo [public_sshKey id $ids(1) proxy %proxy%]

    set port [getDictionaryValue $sshInfo port]
    set privateKey [getDictionaryValue $sshInfo privateKey]

    if {![isValidPort $port]} then {
      error [appendArgs "invalid SSH port: " $port]
    }

    if {![stringIsSshPrivateKey $privateKey]} then {
      error "invalid SSH private key format"
    }

    public_deleteVm id $ids(1) proxy %proxy%

    list true
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids sshInfo port privateKey
  } -constraints $commonConstraints -result {true}}]
}; unset -nocomplain proxy

###############################################################################

if {[hasRuntimeOption remoteChelsea]} then {
  wgQuickDown $test_channel $wireGuardFile
  catch {file delete $wireGuardFile}
}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
