###############################################################################
#
# images.eagle --
#
# This file contains E2E tests for base image creation and management.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

catch {info previouspid true}

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file that do not
#       require any plugins to be loaded.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################

runTest {test images-1.0 {list base images (default only)} -body {
  set result [execInternalApiCurlCommand path /api/images]
  set json [getDictionaryValue $result stdOut]

  if {![isValidJson $json]} then {
    error [appendArgs "invalid response JSON: " $json]
  }

  set images [jsonArrayToList [getViaJsonPaths json $json jpaths [list images]]]

  if {$images eq ""} then {
    error [appendArgs "no images array in response: " $json]
  }

  # Check that at least the default image exists
  set hasDefault false
  foreach img $images {
    if {[getViaJsonPaths json $img jpaths [list image_name]] eq "default"} then {
      set hasDefault true
      break
    }
  }

  if {!$hasDefault} then {
    error [appendArgs "default image not found in: " $json]
  }

  list true
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain result json images hasDefault img
} -constraints $commonConstraints -result {true}}

###############################################################################

runTest {test images-1.1 {create base image from docker} -body {
  #
  # NOTE: This test requires the chelsea-ubuntu-24.04 Docker image to be
  #       available locally. It creates a base image from this Docker image
  #       and verifies the creation completes successfully.
  #
  set imageName [appendArgs test-image- [clock seconds]]

  # Create the base image - data is passed as 3rd positional param
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"chelsea-ubuntu-24.04\"},\"size_mib\":512}"]

  set result [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  set json [getDictionaryValue $result stdOut]

  if {![isValidJson $json]} then {
    error [appendArgs "invalid response JSON from create: " $json]
  }

  set status [getViaJsonPaths json $json jpaths [list status]]

  if {$status ni [list pending completed]} then {
    error [appendArgs "unexpected status from create: " $status " json: " $json]
  }

  # Poll for completion (max 60 seconds)
  set timeout 60
  set start [clock seconds]

  while {true} {
    set elapsed [expr {[clock seconds] - $start}]

    if {$elapsed > $timeout} then {
      error [appendArgs "image creation timed out after " $timeout " seconds"]
    }

    set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
    set statusJson [getDictionaryValue $statusResult stdOut]

    if {![isValidJson $statusJson]} then {
      after 1000; continue
    }

    set currentStatus [getViaJsonPaths json $statusJson jpaths [list status]]

    if {$currentStatus eq "completed"} then {
      break
    } elseif {$currentStatus eq "failed"} then {
      set errorMsg [getViaJsonPaths json $statusJson jpaths [list error] default "unknown"]
      error [appendArgs "image creation failed: " $errorMsg]
    }

    after 1000; # wait 1 second before polling again
  }

  # Verify the image appears in the list
  set listResult [execInternalApiCurlCommand path /api/images]
  set listJson [getDictionaryValue $listResult stdOut]

  if {![isValidJson $listJson]} then {
    error [appendArgs "invalid list response JSON: " $listJson]
  }

  set images [jsonArrayToList [getViaJsonPaths json $listJson jpaths [list images]]]
  set found false

  foreach img $images {
    if {[getViaJsonPaths json $img jpaths [list image_name]] eq $imageName} then {
      set found true
      break
    }
  }

  if {!$found} then {
    error [appendArgs "created image not found in list: " $listJson]
  }

  list true $imageName
} -cleanup {
  # Clean up the created image
  if {[info exists imageName]} then {
    catch {execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]}
  }

  catch {info previouspid true}

  unset -nocomplain imageName payload result json status timeout start \
      elapsed statusResult statusJson currentStatus errorMsg listResult \
      listJson images found img
} -constraints [concat $commonConstraints [list knownBug]] -match glob -result {true test-image-*}}

###############################################################################

runTest {test images-1.2 {create base image with custom size} -body {
  set imageName [appendArgs test-image-sized- [clock seconds]]
  set customSize 1024

  # Create the base image with custom size
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"chelsea-ubuntu-24.04\"},\"size_mib\":" $customSize "}"]

  set result [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  set json [getDictionaryValue $result stdOut]

  if {![isValidJson $json]} then {
    error [appendArgs "invalid response JSON from create: " $json]
  }

  # Poll for completion
  set timeout 60
  set start [clock seconds]

  while {true} {
    set elapsed [expr {[clock seconds] - $start}]

    if {$elapsed > $timeout} then {
      error "image creation timed out"
    }

    set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
    set statusJson [getDictionaryValue $statusResult stdOut]

    if {![isValidJson $statusJson]} then {
      after 1000; continue
    }

    set currentStatus [getViaJsonPaths json $statusJson jpaths [list status]]

    if {$currentStatus eq "completed"} then {
      # Verify the size matches
      set reportedSize [getViaJsonPaths json $statusJson jpaths [list size_mib]]

      if {$reportedSize != $customSize} then {
        error [appendArgs "size mismatch: expected " $customSize " got " $reportedSize]
      }

      break
    } elseif {$currentStatus eq "failed"} then {
      set errorMsg [getViaJsonPaths json $statusJson jpaths [list error] default "unknown"]
      error [appendArgs "image creation failed: " $errorMsg]
    }

    after 1000
  }

  list true $customSize
} -cleanup {
  if {[info exists imageName]} then {
    catch {execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]}
  }

  catch {info previouspid true}

  unset -nocomplain imageName customSize payload result json timeout start \
      elapsed statusResult statusJson currentStatus reportedSize errorMsg
} -constraints [concat $commonConstraints [list knownBug]] -result {true 1024}}

###############################################################################

runTest {test images-1.3 {verify created image has correct snapshot} -body {
  set imageName [appendArgs test-snapshot-image- [clock seconds]]

  # Create the base image
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"chelsea-ubuntu-24.04\"},\"size_mib\":512}"]

  set result [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  set json [getDictionaryValue $result stdOut]

  if {![isValidJson $json]} then {
    error [appendArgs "invalid response JSON from create: " $json]
  }

  # Poll for image creation completion
  set timeout 60
  set start [clock seconds]

  while {true} {
    set elapsed [expr {[clock seconds] - $start}]

    if {$elapsed > $timeout} then {
      error "image creation timed out"
    }

    set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
    set statusJson [getDictionaryValue $statusResult stdOut]

    if {![isValidJson $statusJson]} then {
      after 1000; continue
    }

    set currentStatus [getViaJsonPaths json $statusJson jpaths [list status]]

    if {$currentStatus eq "completed"} then {
      break
    } elseif {$currentStatus eq "failed"} then {
      set errorMsg [getViaJsonPaths json $statusJson jpaths [list error] default "unknown"]
      error [appendArgs "image creation failed: " $errorMsg]
    }

    after 1000
  }

  # Verify the image appears in the list with correct snapshot name
  set listResult [execInternalApiCurlCommand path /api/images]
  set listJson [getDictionaryValue $listResult stdOut]

  if {![isValidJson $listJson]} then {
    error [appendArgs "invalid list response JSON: " $listJson]
  }

  set images [jsonArrayToList [getViaJsonPaths json $listJson jpaths [list images]]]
  set found false
  set snapshotName ""

  foreach img $images {
    if {[getViaJsonPaths json $img jpaths [list image_name]] eq $imageName} then {
      set found true
      set snapshotName [getViaJsonPaths json $img jpaths [list snapshot_name] default ""]
      break
    }
  }

  if {!$found} then {
    error [appendArgs "created image not found in list: " $listJson]
  }

  # Verify the snapshot name is chelsea_base_image (the protected snapshot)
  if {$snapshotName ne "chelsea_base_image"} then {
    error [appendArgs "unexpected snapshot name: " $snapshotName " expected: chelsea_base_image"]
  }

  list true $imageName $snapshotName
} -cleanup {
  if {[info exists imageName]} then {
    catch {execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]}
  }

  catch {info previouspid true}

  unset -nocomplain imageName payload result json timeout start elapsed \
      statusResult statusJson currentStatus errorMsg listResult listJson \
      images found snapshotName img
} -constraints [concat $commonConstraints [list knownBug]] -match glob -result {true test-snapshot-image-* chelsea_base_image}}

###############################################################################

runTest {test images-2.0 {delete base image} -body {
  set imageName [appendArgs test-delete-image- [clock seconds]]

  # Create an image
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"chelsea-ubuntu-24.04\"},\"size_mib\":512}"]

  set result [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  # Wait for completion
  set timeout 60
  set start [clock seconds]

  while {true} {
    set elapsed [expr {[clock seconds] - $start}]

    if {$elapsed > $timeout} then {
      error "image creation timed out"
    }

    set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
    set statusJson [getDictionaryValue $statusResult stdOut]

    if {![isValidJson $statusJson]} then {
      after 1000; continue
    }

    set currentStatus [getViaJsonPaths json $statusJson jpaths [list status]]

    if {$currentStatus eq "completed"} then {
      break
    } elseif {$currentStatus eq "failed"} then {
      error "image creation failed"
    }

    after 1000
  }

  # Delete the image
  set deleteResult [execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]]
  set deleteJson [getDictionaryValue $deleteResult stdOut]

  if {![isValidJson $deleteJson]} then {
    error [appendArgs "invalid delete response JSON: " $deleteJson]
  }

  set deleteStatus [getViaJsonPaths json $deleteJson jpaths [list status] default ""]

  if {$deleteStatus ne "deleted"} then {
    error [appendArgs "unexpected delete status: " $deleteStatus " json: " $deleteJson]
  }

  # Verify image no longer appears in list
  set listResult [execInternalApiCurlCommand path /api/images]
  set listJson [getDictionaryValue $listResult stdOut]

  if {![isValidJson $listJson]} then {
    error [appendArgs "invalid list response JSON: " $listJson]
  }

  set images [jsonArrayToList [getViaJsonPaths json $listJson jpaths [list images]]]
  set stillExists false

  foreach img $images {
    if {[getViaJsonPaths json $img jpaths [list image_name]] eq $imageName} then {
      set stillExists true
      break
    }
  }

  if {$stillExists} then {
    error [appendArgs "deleted image still exists in list: " $listJson]
  }

  list true
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain imageName payload result timeout start elapsed \
      statusResult statusJson currentStatus deleteResult deleteJson \
      deleteStatus listResult listJson images stillExists img
} -constraints [concat $commonConstraints [list knownBug]] -result {true}}

###############################################################################

runTest {test images-2.1 {duplicate image name rejected} -body {
  set imageName [appendArgs test-dup-image- [clock seconds]]

  # Create first image
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"chelsea-ubuntu-24.04\"},\"size_mib\":512}"]

  set result1 [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  # Wait for first image completion
  set timeout 60
  set start [clock seconds]

  while {true} {
    set elapsed [expr {[clock seconds] - $start}]

    if {$elapsed > $timeout} then {
      error "first image creation timed out"
    }

    set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
    set statusJson [getDictionaryValue $statusResult stdOut]

    if {![isValidJson $statusJson]} then {
      after 1000; continue
    }

    set currentStatus [getViaJsonPaths json $statusJson jpaths [list status]]

    if {$currentStatus eq "completed"} then {
      break
    } elseif {$currentStatus eq "failed"} then {
      error "first image creation failed"
    }

    after 1000
  }

  # Try to create second image with same name - should fail
  set result2 [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  set json2 [getDictionaryValue $result2 stdOut]

  if {![isValidJson $json2]} then {
    error [appendArgs "invalid response JSON from second create: " $json2]
  }

  # Should have an error about duplicate name
  set errorField [getViaJsonPaths json $json2 jpaths [list error] default ""]

  if {$errorField eq ""} then {
    error [appendArgs "expected error for duplicate name, got: " $json2]
  }

  list true
} -cleanup {
  if {[info exists imageName]} then {
    catch {execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]}
  }

  catch {info previouspid true}

  unset -nocomplain imageName payload result1 timeout start elapsed \
      statusResult statusJson currentStatus result2 json2 errorField
} -constraints [concat $commonConstraints [list knownBug]] -result {true}}

###############################################################################

runTest {test images-2.2 {invalid docker image rejected} -body {
  set imageName [appendArgs test-invalid-image- [clock seconds]]

  # Try to create image from non-existent Docker image
  set payload [appendArgs \
      "{\"image_name\":\"" $imageName \
      "\",\"source\":{\"type\":\"docker\",\"image_ref\":\"nonexistent-image-12345\"},\"size_mib\":512}"]

  set result [execInternalApiCurlCommand method POST path /api/images/create data $payload]

  set json [getDictionaryValue $result stdOut]

  if {![isValidJson $json]} then {
    error [appendArgs "invalid response JSON: " $json]
  }

  # Wait a moment for the async operation to fail
  after 2000

  set statusResult [execInternalApiCurlCommand path [appendArgs /api/images/ $imageName /status]]
  set statusJson [getDictionaryValue $statusResult stdOut]

  if {![isValidJson $statusJson]} then {
    # Image might not exist at all if it failed immediately
    list true
  } else {
    set status [getViaJsonPaths json $statusJson jpaths [list status] default ""]

    if {$status eq "failed"} then {
      list true
    } elseif {$status eq ""} then {
      # Image doesn't exist (immediate failure)
      list true
    } else {
      error [appendArgs "expected failure status, got: " $statusJson]
    }
  }
} -cleanup {
  if {[info exists imageName]} then {
    catch {execInternalApiCurlCommand method DELETE path [appendArgs /api/images/ $imageName]}
  }

  catch {info previouspid true}

  unset -nocomplain imageName payload result json statusResult statusJson \
      status
} -constraints $commonConstraints -result {true}}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
