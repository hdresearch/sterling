###############################################################################
#
# commit_tags.eagle --
#
# This file contains end-to-end integration tests for the commit tags feature.
# Tags provide mutable named pointers to VM commits.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################
# Tag CRUD Tests (commit-tags-100.x)
###############################################################################

runTest {test commit-tags-100.0 {create and get tag} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM and commit it to get a commit_id
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # Create a tag pointing to this commit
  set tagName [appendArgs "test-tag-" [clock seconds]]
  set tagJson [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) \
      "\",\"description\":\"Test tag for commit-tags-100.0\"\}"]

  set createResult [public_createTag json $tagJson proxy 0]
  set createdTagId [jqRawString $createResult .tag_id]

  # Verify tag was created by getting it
  set getResult [public_getTag tag_name $tagName proxy 0]
  set gotTagName [jqRawString $getResult .tag_name]
  set gotCommitId [jqRawString $getResult .commit_id]

  # Delete the tag
  public_deleteTag tag_name $tagName proxy 0

  # Cleanup: delete the VM
  public_deleteVm id $ids(vm) proxy 0

  list [string equal $gotTagName $tagName] \
       [string equal $gotCommitId $ids(commit)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName tagJson createResult createdTagId \
      getResult gotTagName gotCommitId
} -constraints $commonConstraints -result {True True}}

###############################################################################

runTest {test commit-tags-101.0 {list tags} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM and commit
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # Create two tags
  set ts [clock seconds]
  set tagName1 [appendArgs "test-list-tag-1-" $ts]
  set tagName2 [appendArgs "test-list-tag-2-" $ts]

  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName1 \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName2 \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  # List tags and verify both exist
  set listResult [public_listTags proxy 0]
  set tagNames [jqRawString $listResult {.tags[].tag_name}]

  set found1 [expr {[string first $tagName1 $tagNames] >= 0}]
  set found2 [expr {[string first $tagName2 $tagNames] >= 0}]

  # Cleanup
  public_deleteTag tag_name $tagName1 proxy 0
  public_deleteTag tag_name $tagName2 proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list $found1 $found2
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts tagName1 tagName2 listResult tagNames found1 found2
} -constraints $commonConstraints -result {True True}}

###############################################################################

runTest {test commit-tags-102.0 {update tag to new commit} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM and make two commits
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit1) [public_commitVm id $ids(vm) proxy 0]
  set ids(commit2) [public_commitVm id $ids(vm) proxy 0]

  # Create tag pointing to first commit
  set tagName [appendArgs "test-update-tag-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit1) "\"\}"] proxy 0

  # Verify tag points to first commit
  set getResult1 [public_getTag tag_name $tagName proxy 0]
  set initialCommitId [jqRawString $getResult1 .commit_id]

  # Update tag to point to second commit
  public_updateTag tag_name $tagName json [appendArgs \
      "\{\"commit_id\":\"" $ids(commit2) "\"\}"] proxy 0

  # Verify tag now points to second commit
  set getResult2 [public_getTag tag_name $tagName proxy 0]
  set updatedCommitId [jqRawString $getResult2 .commit_id]

  # Cleanup
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list [string equal $initialCommitId $ids(commit1)] \
       [string equal $updatedCommitId $ids(commit2)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName getResult1 getResult2 \
      initialCommitId updatedCommitId
} -constraints $commonConstraints -result {True True}}

###############################################################################

runTest {test commit-tags-103.0 {update tag description} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM and commit
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # Create tag with initial description
  set tagName [appendArgs "test-desc-tag-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) \
      "\",\"description\":\"Initial description\"\}"] proxy 0

  # Update description
  set newDescription "Updated description for test"
  public_updateTag tag_name $tagName json [appendArgs \
      "\{\"description\":\"" $newDescription "\"\}"] proxy 0

  # Verify description was updated
  set getResult [public_getTag tag_name $tagName proxy 0]
  set gotDescription [jqRawString $getResult .description]

  # Cleanup
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  string equal $gotDescription $newDescription
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName newDescription getResult gotDescription
} -constraints $commonConstraints -result {True}}

###############################################################################
# Tag Uniqueness Tests (commit-tags-110.x)
###############################################################################

runTest {test commit-tags-110.0 {reject duplicate tag names} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM and commit
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # Create first tag
  set tagName [appendArgs "duplicate-test-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  # Try to create duplicate (should fail with 409 Conflict)
  set duplicateFailed [catch {
    public_createTag json [appendArgs \
        "\{\"tag_name\":\"" $tagName \
        "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0
  } err]

  # Cleanup
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  set duplicateFailed
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName duplicateFailed err
} -constraints $commonConstraints -result {1}}

###############################################################################
# VM Operations with Tags Tests (commit-tags-200.x)
###############################################################################

runTest {test commit-tags-200.0 {branch VM by tag} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM, commit, and tag
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set tagName [appendArgs "branch-test-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  # Branch by tag
  set branchResult [public_branchByTag tag_name $tagName proxy 0]
  set ids(branched) [jqRawString $branchResult {.vms[0].vm_id}]

  # Verify branched VM exists (has valid UUID format)
  set branchedVmValid [isValidVirtualMachineId $ids(branched)]

  # Cleanup
  catch { public_deleteVm id $ids(branched) proxy 0 }
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  set branchedVmValid
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName branchResult branchedVmValid
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test commit-tags-201.0 {branch multiple VMs by tag} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM, commit, and tag
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set tagName [appendArgs "branch-multi-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  # Branch 2 VMs by tag
  set branchResult [public_branchByTag tag_name $tagName proxy 0 count 2]
  set branchedVmCount [jq $branchResult {.vms | length}]

  # Get VM IDs for cleanup
  set branchedVmIds [list]
  for {set i 0} {$i < $branchedVmCount} {incr i} {
    lappend branchedVmIds [jqRawString $branchResult ".vms\[$i\].vm_id"]
  }

  # Cleanup
  foreach branchedId $branchedVmIds {
    catch { public_deleteVm id $branchedId proxy 0 }
  }
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  expr {$branchedVmCount == 2}
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName branchResult branchedVmCount \
      branchedVmIds branchedId i
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test commit-tags-202.0 {restore VM from tag} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM, commit, and tag
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set tagName [appendArgs "restore-test-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit) "\"\}"] proxy 0

  # Delete original VM
  public_deleteVm id $ids(vm) proxy 0

  # Restore from tag
  set ids(restored) [public_resumeVmByTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName "\"\}"] proxy 0]

  # Verify restored VM exists
  set restoredVmValid [isValidVirtualMachineId $ids(restored)]

  # Cleanup
  catch { public_deleteVm id $ids(restored) proxy 0 }
  public_deleteTag tag_name $tagName proxy 0

  set restoredVmValid
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids tagName restoredVmValid
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test commit-tags-203.0 {branch from updated tag verifies state} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM and get IP
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ips(vm) [jqRawString [internal_network id $ids(vm)] .vm_ipv4]

  # Write marker file and commit
  set marker1 [appendArgs "marker1-" [clock seconds]]
  execApiSshCommand $ips(vm) $ids(vm) false \
      echo [appendArgs ' $marker1 '] > /tmp/marker.txt

  set ids(commit1) [public_commitVm id $ids(vm) proxy 0]

  # Write different marker and commit again
  set marker2 [appendArgs "marker2-" [clock seconds]]
  execApiSshCommand $ips(vm) $ids(vm) false \
      echo [appendArgs ' $marker2 '] > /tmp/marker.txt

  set ids(commit2) [public_commitVm id $ids(vm) proxy 0]

  # Create tag pointing to first commit
  set tagName [appendArgs "rolling-tag-" [clock seconds]]
  public_createTag json [appendArgs \
      "\{\"tag_name\":\"" $tagName \
      "\",\"commit_id\":\"" $ids(commit1) "\"\}"] proxy 0

  # Update tag to point to second commit
  public_updateTag tag_name $tagName json [appendArgs \
      "\{\"commit_id\":\"" $ids(commit2) "\"\}"] proxy 0

  # Branch from tag (should get second commit's state)
  set branchResult [public_branchByTag tag_name $tagName proxy 0]
  set ids(branched) [jqRawString $branchResult {.vms[0].vm_id}]
  set ips(branched) [jqRawString [internal_network id $ids(branched)] .vm_ipv4]

  # Read marker file from branched VM
  set markerContent [getDictionaryValue [execApiSshCommand \
      $ips(branched) $ids(branched) false cat /tmp/marker.txt] stdOut]

  # Cleanup
  catch { public_deleteVm id $ids(branched) proxy 0 }
  public_deleteTag tag_name $tagName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  # Verify branched VM has second marker (from updated tag)
  string match "*$marker2*" $markerContent
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ips marker1 marker2 tagName branchResult markerContent
} -constraints $commonConstraints -result {True}}

###############################################################################
# Error Handling Tests (commit-tags-300.x)
###############################################################################

runTest {test commit-tags-300.0 {branch from non-existent tag returns error} -body {
  set code [catch {
    public_branchByTag tag_name [appendArgs \
        "non-existent-tag-" [clock seconds]] proxy 0
  } result]

  list $code [string match -nocase "*not found*" $result]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain code result
} -constraints $commonConstraints -result {1 True}}

