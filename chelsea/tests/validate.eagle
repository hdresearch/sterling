} -constraints $validateConstraints -result {0}}

###############################################################################
#
# randomIPv4 — produces valid IPv4 addresses
#
###############################################################################

runTest {test validate-4.0 {randomIPv4 produces valid IPv4 addresses} -body {
  set count 0

  for {set i 0} {$i < 10} {incr i} {
    set ip [randomIPv4]

    if {[string is inetaddr -strict $ip]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count i ip
} -constraints $validateConstraints -result {10}}

###############################################################################
#
# randomIPv4 — avoids reserved and private ranges
#
###############################################################################

runTest {test validate-4.1 {randomIPv4 avoids reserved ranges} -body {
  set allGood true

  for {set i 0} {$i < 20} {incr i} {
    set ip [randomIPv4]
    set octets [split $ip .]
    set a [lindex $octets 0]
    set b [lindex $octets 1]

    #
    # NOTE: Verify the IP is not in known reserved ranges.
    #
    if {$a == 0 || $a == 10 || $a == 127 || $a >= 224} then {
      set allGood false; break
    }

    if {$a == 172 && $b >= 16 && $b <= 31} then {
      set allGood false; break
    }

    if {$a == 192 && $b == 168} then {
      set allGood false; break
    }
  }

  set allGood
} -cleanup {
  unset -nocomplain allGood i ip octets a b
} -constraints $validateConstraints -result {true}}

###############################################################################
#
# randomIPv6 — produces valid 8-group hex format
#
###############################################################################

runTest {test validate-4.2 {randomIPv6 produces valid format} -body {
  set count 0

  for {set i 0} {$i < 10} {incr i} {
    set ip [randomIPv6]

    #
    # NOTE: Valid IPv6 should be 8 groups of 4 hex digits separated
    #       by colons.
    #
    if {[regexp -- {^[0-9a-f]{4}(?::[0-9a-f]{4}){7}$} $ip]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count i ip
} -constraints $validateConstraints -result {10}}

###############################################################################
#
# randomIPv6 — produces global unicast addresses (2000::/3)
#
###############################################################################

runTest {test validate-4.3 {randomIPv6 produces global unicast addresses} -body {
  set allGood true

  for {set i 0} {$i < 20} {incr i} {
    set ip [randomIPv6]
    set groups [split $ip :]
    set g1 [expr [appendArgs 0x [lindex $groups 0]]]

    #
    # NOTE: Global unicast range is 2000::/3, so first group must be
    #       in [0x2000, 0x3fff].
    #
    if {$g1 < 0x2000 || $g1 > 0x3fff} then {
      set allGood false; break
    }

    #
    # NOTE: Also verify excluded ranges are avoided.
    #
    if {$g1 == 0x2001 || $g1 == 0x2002 || $g1 == 0x3fff} then {
      set allGood false; break
    }
  }

  set allGood
} -cleanup {
  unset -nocomplain allGood i ip groups g1
} -constraints $validateConstraints -result {true}}

###############################################################################
#
# buildFullUri — constructs URI with query parameters
#
###############################################################################

runTest {test validate-5.0 {buildFullUri constructs URI with query params} -body {
  set result [buildFullUri http://example.com/api \
      [list key value name test]]

  string match http://example.com/api?key=value&name=test $result
} -cleanup {
  unset -nocomplain result
} -constraints $validateConstraints -result {True}}

###############################################################################
#
# buildFullUri — returns base URI when query is empty
#
###############################################################################

runTest {test validate-5.1 {buildFullUri returns base URI for empty query} -body {
  buildFullUri http://example.com/api [list]
} -cleanup {
  #
  # NOTE: Nothing to clean up.
  #
} -constraints $validateConstraints -result {http://example.com/api}}

###############################################################################
#
# verifyHttpResponseCode — accepts matching response code
#
###############################################################################

runTest {test validate-5.2 {verifyHttpResponseCode accepts matching code} -body {
  set response [list \
      exitCode Success responseCode 200 stdOut "" stdErr ""]

  verifyHttpResponseCode $response 200

  list ok
} -cleanup {
  unset -nocomplain response
} -constraints $validateConstraints -result {ok}}

###############################################################################
#
# verifyHttpResponseCode — rejects mismatched response code
#
###############################################################################

runTest {test validate-5.3 {verifyHttpResponseCode rejects mismatched code} -body {
  set response [list \
      exitCode Success responseCode 404 stdOut "" stdErr ""]

  set code [catch {verifyHttpResponseCode $response 200} result]

  list $code [string match "*bad HTTP response code*" $result]
} -cleanup {
  unset -nocomplain response code result
} -constraints $validateConstraints -result {1 True}}

###############################################################################
#
# verifyHttpResponseCode — rejects non-200 when 200 expected
#
###############################################################################

runTest {test validate-5.4 {verifyHttpResponseCode rejects 500 for 200} -body {
  set response [list \
      exitCode Success responseCode 500 stdOut "" stdErr ""]

  set code [catch {verifyHttpResponseCode $response 200} result]

  list $code [string match "*not OK*" $result]
} -cleanup {
  unset -nocomplain response code result
} -constraints $validateConstraints -result {1 True}}

###############################################################################
#
# verifyHttpResponseCode — rejects mismatched non-200 codes
#
###############################################################################

runTest {test validate-5.5 {verifyHttpResponseCode rejects 404 for 201} -body {
  set response [list \
      exitCode Success responseCode 404 stdOut "" stdErr ""]

  set code [catch {verifyHttpResponseCode $response 201} result]

  list $code [string match "*mismatched HTTP response code*" $result]
} -cleanup {
  unset -nocomplain response code result
} -constraints $validateConstraints -result {1 True}}

###############################################################################
#
# getHttpVerbs — returns standard HTTP method list
#
###############################################################################

runTest {test validate-5.6 {getHttpVerbs returns standard HTTP methods} -body {
  set verbs [getHttpVerbs]

  list \
      [llength $verbs] \
      [expr {[lsearch -exact $verbs GET] != -1}] \
      [expr {[lsearch -exact $verbs POST] != -1}] \
      [expr {[lsearch -exact $verbs DELETE] != -1}]
} -cleanup {
  unset -nocomplain verbs
} -constraints $validateConstraints -result {9 True True True}}

