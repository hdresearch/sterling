#
###############################################################################

runTest {test validate-3.0 {randomHexInteger returns 16-char hex string} -body {
  set hex [randomHexInteger]
  set length [string length $hex]
  set isHex [regexp -- {^[0-9a-f]{16}$} $hex]

  list $length $isHex
} -cleanup {
  unset -nocomplain hex length isHex
} -constraints $validateConstraints -result {16 1}}

