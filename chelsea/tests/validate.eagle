###############################################################################
#
# validate.eagle --
#
# This file contains tests for the validation and utility functions in
# the Chelsea library (value.eagle, network.eagle, web.eagle).  These
# tests verify correctness of pure utility functions and do not require
# a running Chelsea daemon.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

catch {info previouspid true}

###############################################################################
#
# isValidPort — accepts valid port numbers
#
###############################################################################

runTest {test validate-1.0 {isValidPort accepts valid port numbers} -body {
  set count 0

  foreach port [list 0 1 22 80 443 8080 8111 65535] {
    if {[isValidPort $port]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count port
} -constraints $validateConstraints -result {8}}

###############################################################################
#
# isValidPort — rejects invalid port numbers
#
###############################################################################

runTest {test validate-1.1 {isValidPort rejects invalid port numbers} -body {
  set count 0

  foreach port [list -1 65536 abc "" 999999] {
    if {[isValidPort $port]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count port
} -constraints $validateConstraints -result {0}}

###############################################################################
#
# isValidId — accepts a valid GUID
#
###############################################################################

runTest {test validate-1.2 {isValidId accepts valid GUID} -body {
  set id [guid new]

  if {[isValidId $id]} then {
    list true
  } else {
    list false $id
  }
} -cleanup {
  unset -nocomplain id
} -constraints $validateConstraints -result {true}}

