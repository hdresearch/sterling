###############################################################################
#
# isValidClusterId — accepts valid flickrBase58 22-character strings
#
###############################################################################

runTest {test validate-1.6 {isValidClusterId accepts valid flickrBase58} -body {
  set count 0

  #
  # NOTE: Valid flickrBase58 characters exclude: 0, O, I, l.
  #       Each test value is exactly 22 characters from the valid set.
  #
  foreach id [list \
      123456789abcdefghijkmn \
      ABCDEFGHJKLMNPQRSTUVzz \
      2222222222222222222222] {
    if {[isValidClusterId $id]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count id
} -constraints $validateConstraints -result {3}}

