  set sshKey [appendArgs \
      "-----BEGIN OPENSSH PRIVATE KEY-----\n" \
      b3BlbnNzaC1rZXktdjEAAAAABG5vbmUAAAAEbm9uZQ== \
      "\n-----END OPENSSH PRIVATE KEY-----"]

  if {[stringIsSshPrivateKey $sshKey]} then {
    list true
  } else {
    list false
  }
} -cleanup {
  unset -nocomplain sshKey
} -constraints $validateConstraints -result {true}}

