#
# isValidClusterId — rejects invalid values
#
###############################################################################

runTest {test validate-1.7 {isValidClusterId rejects invalid values} -body {
  set count 0

  foreach id [list \
      "" \
      short \
      123456789abcdefghijkm \
      0000000000000000000000] {
    if {[isValidClusterId $id]} then {
      incr count
    }
  }

  set count
} -cleanup {
  unset -nocomplain count id
} -constraints $validateConstraints -result {0}}

