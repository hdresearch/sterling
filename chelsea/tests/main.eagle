###############################################################################
#
# main.eagle --
#
# This file contains end-to-end integration tests for this project.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

catch {info previouspid true}

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file that do not
#       require any plugins to be loaded.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################

if {[info exists wireGuardFile] && \
    [hasRuntimeOption remoteChelsea]} then {
  writeFile $wireGuardFile ""; # TODO: Fix me.
  wgQuickUp $test_channel $wireGuardFile
}

###############################################################################

runTest {test chelsea-100.0 {use the version endpoint} -body {
  regexp -- {"executable_name"\s*:\s*"chelsea"} [internal_version]
} -cleanup {
  catch {info previouspid true}
} -constraints $commonConstraints -result {1}}

###############################################################################

runTest {test chelsea-101.0 {use the health endpoint} -body {
  internal_health
} -cleanup {
  catch {info previouspid true}
} -constraints $commonConstraints -result {ok}}

###############################################################################

runTest {test chelsea-102.0 {use the telemetry endpoint} -body {
  set json [internal_telemetry]

  foreach jpath [list \
      .ram.real_mib_total .ram.real_mib_available \
      .ram.vm_mib_total .ram.vm_mib_available \
      .cpu.real_total .cpu.real_available \
      .cpu.vcpu_count_total .cpu.vcpu_count_vm_total \
      .cpu.vcpu_count_vm_available .fs.mib_total \
      .fs.mib_available .chelsea.vm_count_max \
      .chelsea.vm_count_current] {
    set value [jq $json $jpath]

    if {![string is double -strict $value]} then {
      error [appendArgs \
          "telemetry value \"" $jpath "\" is not a valid double: " \
          $value]
    }
  }
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain value json jpath
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test chelsea-103.0 {create / delete VM (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  string equal $ids(1) [internal_deleteVm id $ids(1)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test chelsea-104.0 {create, SSH, and commit VM} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

  set entropy [clock seconds]

  set text(old) [appendArgs \
      "This is test chelsea-104.0 of the test suite: " $entropy]

  set fileName [file join \
      [getTemporaryPath] [appendArgs test- $entropy .txt]]

  execApiSshCommand $ips(1) $ids(1) false \
      echo [appendArgs ' $text(old) '] > $fileName

  set ids(2) [internal_commitVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal commitVm]]]

  internal_deleteVm id $ids(1)

  set ids(3) [internal_resumeVm id $ids(2) json [processJsonTemplate \
      internal [getJsonTemplate internal resumeVm]]]

  set ips(3) [jqRawString [internal_network id $ids(3)] .vm_ipv4]

  set text(new) [getDictionaryValue [execApiSshCommand \
      $ips(3) $ids(3) false cat $fileName] stdOut]

  internal_deleteVm id $ids(3)

  if {$text(new) ne $text(old)} then {
    error [appendArgs \
        "mismatched test file contents: have \"" $text(new) \
        "\", want \"" $text(old) \"]
  }
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ips entropy fileName text
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test chelsea-105.0 {create, SSH, and sleep+wake VM (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

  set entropy [clock seconds]

  set text(old) [appendArgs \
      "This is test chelsea-105.0 of the test suite: " $entropy]

  set fileName [file join \
      [getTemporaryPath] [appendArgs test- $entropy .txt]]

  execApiSshCommand $ips(1) $ids(1) false \
      echo [appendArgs ' $text(old) '] > $fileName

  internal_sleepVm id $ids(1)

  set state(1) [internal_getVmState id $ids(1)]

  if {$state(1) ne "sleeping"} {
    error [appendArgs "expected state of VM " $ids(1) " to be \"sleeping\", got \"" $state(1) "\""]
  }

  internal_wakeVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal wakeVm]]

  set state(1) [internal_getVmState id $ids(1)]

  if {$state(1) ne "running"} {
    error [appendArgs "expected state of VM " $ids(1) " to be \"running\", got \"" $state(1) "\""]
  }

  set text(new) [getDictionaryValue [execApiSshCommand \
    $ips(1) $ids(1) false cat $fileName] stdOut]

  if {$text(new) ne $text(old)} then {
    error [appendArgs \
        "mismatched test file contents: have \"" $text(new) \
        "\", want \"" $text(old) \"]
  }

  string equal $ids(1) [internal_deleteVm id $ids(1)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ips entropy fileName text state
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test chelsea-113.0 {create VM, resize disk (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

  #
  # NOTE: Verify the initial disk size inside the guest.
  #
  set diskBefore [getDictionaryValue [execApiSshCommand \
      $ips(1) $ids(1) false lsblk -b -n -o SIZE /dev/vda] stdOut]

  set diskBefore [string trim $diskBefore]

  #
  # NOTE: Resize the disk to 1.5x the default (1024 MiB).
  #       Keep under 2048 to avoid 32-bit integer overflow in
  #       the expectedBytes calculation (2048*1024*1024 > INT32_MAX).
  #
  set fs_size_mib 1536

  internal_resizeDisk id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal resizeDisk]]

  #
  # NOTE: Verify the disk has grown inside the guest.
  #
  set diskAfter [getDictionaryValue [execApiSshCommand \
      $ips(1) $ids(1) false lsblk -b -n -o SIZE /dev/vda] stdOut]

  set diskAfter [string trim $diskAfter]

  set expectedBytes [expr {$fs_size_mib * 1024 * 1024}]

  if {$diskAfter != $expectedBytes} then {
    error [appendArgs \
        "disk size mismatch after resize: have " $diskAfter \
        " bytes, want " $expectedBytes " bytes"]
  }

  if {$diskAfter <= $diskBefore} then {
    error [appendArgs \
        "disk did not grow: before=" $diskBefore \
        " after=" $diskAfter]
  }

  #
  # NOTE: Verify the filesystem was also expanded (resize2fs ran).
  #       Use "df /" (root mount) rather than "df /dev/vda" to avoid
  #       device-name ambiguity.  The 1K-block total is compared to
  #       the block device size; it must be at least 75 % of the raw
  #       device to confirm resize2fs ran (ext4 overhead is ~5-10 %).
  #
  set fsSizeKb [getDictionaryValue [execApiSshCommand \
      $ips(1) $ids(1) false df --output=size /] stdOut]

  set fsSizeKb [string trim [lindex [split [string trim $fsSizeKb] \n] end]]

  set minExpectedKb [expr {$fs_size_mib * 1024 * 3 / 4}]

  if {$fsSizeKb < $minExpectedKb} then {
    error [appendArgs \
        "filesystem not resized: fs size " $fsSizeKb \
        " KB is less than " $minExpectedKb " KB"]
  }

} -cleanup {
  catch {internal_deleteVm id $ids(1)}

  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ips diskBefore diskAfter expectedBytes \
      fs_size_mib fsSizeKb minExpectedKb
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test chelsea-114.0 {resize disk rejects size above max (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  #
  # NOTE: Attempt to resize to a value well above the configured
  #       chelsea_vm_max_volume_mib (currently 16392 MiB).  The
  #       request should fail with an HTTP error.
  #
  set fs_size_mib 999999

  set code [catch {
    internal_resizeDisk id $ids(1) json [processJsonTemplate \
        internal [getJsonTemplate internal resizeDisk]]
  } result]

  #
  # NOTE: code == 1 means the call threw an error (verifyHttpResponseCode
  #       rejected the non-200 status).  The error message should mention
  #       "maximum" from the HardMaximumViolation error.
  #
  if {$code != 1} then {
    error [appendArgs "expected resize to fail (code 1), got code " $code]
  }

  if {![string match -nocase "*maximum*" $result]} then {
    error [appendArgs "expected error to mention 'maximum', got: " $result]
  }
} -cleanup {
  catch {internal_deleteVm id $ids(1)}

  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids fs_size_mib code result
} -constraints $commonConstraints -result {}}

###############################################################################

foreach proxy [list 0 1] {
  runTest [string map [list %proxy% $proxy] \
      {test chelsea-200.%proxy% {use the version endpoint} -body {
    regexp -- {"executable_name"\s*:\s*"orchestrator"} \
        [public_version proxy %proxy%]
  } -cleanup {
    catch {info previouspid true}

    unset -nocomplain pattern
  } -constraints $commonConstraints -result {1}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-201.%proxy% {create / delete VM (public)} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    string equal $ids(1) [public_deleteVm id $ids(1) proxy %proxy%]
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids
  } -constraints $commonConstraints -result {True}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-202.%proxy% {create, SSH, commit VM} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

    set entropy [clock seconds]

    set text(old) [appendArgs \
        "This is test chelsea-202.%proxy% of the test suite: " $entropy]

    set fileName [file join \
        [getTemporaryPath] [appendArgs test- $entropy .txt]]

    execApiSshCommand $ips(1) $ids(1) false \
        echo [appendArgs ' $text(old) '] > $fileName

    set commit_id [set ids(2) \
        [public_commitVm id $ids(1) proxy %proxy%]]; # ==> resumeVm

    public_deleteVm id $ids(1) proxy %proxy%

    set ids(3) [public_resumeVm id $ids(2) json [processJsonTemplate \
        public [getJsonTemplate public resumeVm]] proxy %proxy%]

    set ips(3) [jqRawString [internal_network id $ids(3)] .vm_ipv4]

    set text(new) [getDictionaryValue [execApiSshCommand \
        $ips(3) $ids(3) false cat $fileName] stdOut]

    public_deleteVm id $ids(3) proxy %proxy%

    if {$text(new) ne $text(old)} then {
      error [appendArgs \
          "mismatched test file contents: have \"" $text(new) \
          "\", want \"" $text(old) \"]
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids ips entropy fileName text
  } -constraints $commonConstraints -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-203.%proxy% {create, SSH, branch VM from commit} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

    set entropy [clock seconds]

    set text(old) [appendArgs \
        "This is test chelsea-203.%proxy% of the test suite: " $entropy]

    set fileName [file join \
        [getTemporaryPath] [appendArgs test- $entropy .txt]]

    execApiSshCommand $ips(1) $ids(1) false \
        echo [appendArgs ' $text(old) '] > $fileName

    set commit_id [set ids(2) \
        [public_commitVm id $ids(1) proxy %proxy%]]; # ==> resumeVm

    public_deleteVm id $ids(1) proxy %proxy%

    set ids(3) [public_branchByCommit id $ids(2) json [processJsonTemplate \
        public [getJsonTemplate public branchByCommit]] proxy %proxy%]

    set ips(3) [jqRawString [internal_network id $ids(3)] .vm_ipv4]

    set text(new) [getDictionaryValue [execApiSshCommand \
        $ips(3) $ids(3) false cat $fileName] stdOut]

    public_deleteVm id $ids(3) proxy %proxy%

    if {$text(new) ne $text(old)} then {
      error [appendArgs \
          "mismatched test file contents: have \"" $text(new) \
          "\", want \"" $text(old) \"]
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids ips entropy fileName text
  } -constraints $commonConstraints -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-204.%proxy% {branch from non-existent commit} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set code [catch {
      public_branchByCommit id $commit_id json [processJsonTemplate \
          public [getJsonTemplate public branchByCommit]] proxy %proxy%
    } result]

    list $code $result [string match -nocase "*not found*" $result]
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain code result
  } -constraints $commonConstraints -result {1 {mismatched HTTP response code:\
  have 404, want 201, from: exitCode Success responseCode 404 stdOut\
  {{"error":"commit not found","success":false}} stdErr {}} True}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-205.%proxy% {create, SSH, branch from VM} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

    set entropy [clock seconds]

    set text(old) [appendArgs \
        "This is test chelsea-205.%proxy% of the test suite: " $entropy]

    set fileName [file join \
        [getTemporaryPath] [appendArgs test- $entropy .txt]]

    execApiSshCommand $ips(1) $ids(1) false \
        echo [appendArgs ' $text(old) '] > $fileName

    set ids(3) [public_branchByVm id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public branchByVm]] proxy %proxy%]

    set ips(3) [jqRawString [internal_network id $ids(3)] .vm_ipv4]

    set text(new) [getDictionaryValue [execApiSshCommand \
        $ips(3) $ids(3) false cat $fileName] stdOut]

    public_deleteVm id $ids(3) proxy %proxy%
    public_deleteVm id $ids(1) proxy %proxy%

    if {$text(new) ne $text(old)} then {
      error [appendArgs \
          "mismatched test file contents: have \"" $text(new) \
          "\", want \"" $text(old) \"]
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids ips entropy fileName text
  } -constraints $commonConstraints -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-206.%proxy% {branch from non-existent VM} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set code [catch {
      public_branchByVm id $commit_id json [processJsonTemplate \
          public [getJsonTemplate public branchByVm]] proxy %proxy%
    } result]

    list $code $result [string match -nocase "*not found*" $result]
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain code result
  } -constraints $commonConstraints -result {1 {mismatched HTTP response code:\
  have 404, want 201, from: exitCode Success responseCode 404 stdOut\
  {{"vms":[],"error":"parent vm not found"}} stdErr {}} True}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-207.%proxy% {get VM metadata} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set metadata [public_vmMetadata id $ids(1) proxy %proxy%]

    set metadataVmId [jqRawString $metadata .vm_id]
    set metadataIp [jqRawString $metadata .ip]
    set metadataState [jqRawString $metadata .state]

    public_deleteVm id $ids(1) proxy %proxy%

    if {$metadataVmId ne $ids(1)} then {
      error [appendArgs \
          "mismatched VM ID in metadata: have \"" $metadataVmId \
          "\", want \"" $ids(1) \"]
    }

    if {[string length $metadataIp] == 0} then {
      error "missing IP address in metadata"
    }

    if {[string length $metadataState] == 0} then {
      error "missing state in metadata"
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids metadata metadataVmId metadataIp metadataState
  } -constraints $commonConstraints -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test chelsea-209.%proxy% {create VM, resize disk (public)} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    set ips(1) [jqRawString [internal_network id $ids(1)] .vm_ipv4]

    #
    # NOTE: Verify the initial disk size inside the guest.
    #
    set diskBefore [getDictionaryValue [execApiSshCommand \
        $ips(1) $ids(1) false lsblk -b -n -o SIZE /dev/vda] stdOut]

    set diskBefore [string trim $diskBefore]

    #
    # NOTE: Resize the disk to 1536 MiB via the public API.
    #       Keep under 2048 to avoid 32-bit integer overflow in
    #       the expectedBytes calculation (2048*1024*1024 > INT32_MAX).
    #
    set fs_size_mib 1536

    public_resizeDisk id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public resizeDisk]] proxy %proxy%

    #
    # NOTE: Verify the disk has grown inside the guest.
    #
    set diskAfter [getDictionaryValue [execApiSshCommand \
        $ips(1) $ids(1) false lsblk -b -n -o SIZE /dev/vda] stdOut]

    set diskAfter [string trim $diskAfter]

    set expectedBytes [expr {$fs_size_mib * 1024 * 1024}]

    if {$diskAfter != $expectedBytes} then {
      error [appendArgs \
          "disk size mismatch after resize: have " $diskAfter \
          " bytes, want " $expectedBytes " bytes"]
    }

    if {$diskAfter <= $diskBefore} then {
      error [appendArgs \
          "disk did not grow: before=" $diskBefore \
          " after=" $diskAfter]
    }

  } -cleanup {
    catch {public_deleteVm id $ids(1) proxy %proxy%}

    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids ips diskBefore diskAfter expectedBytes fs_size_mib
  } -constraints $commonConstraints -result {}}]
}; unset -nocomplain proxy

###############################################################################

runTest {test chelsea-300.0 {use the version endpoint} -body {
  regexp -- {"executable_name"\s*:\s*"proxy"} [proxy_version]
} -cleanup {
  catch {info previouspid true}
} -constraints $commonConstraints -result {1}}

###############################################################################

if {[hasRuntimeOption remoteChelsea]} then {
  wgQuickDown $test_channel $wireGuardFile
  catch {file delete $wireGuardFile}
}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
