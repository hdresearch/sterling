###############################################################################

runTest {test repositories-500.3 {fork private repo fails} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set repoName [appendArgs "private-fork-src-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"latest\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  # Do NOT make public — fork should fail
  set forkJson [appendArgs \
      "\{\"source_org\":\"test_user\"" \
      ",\"source_repo\":\"" $repoName "\"" \
      ",\"source_tag\":\"latest\"\}"]

  set forkFailed [catch {
    public_forkRepository json $forkJson proxy 0
  } err]

  # Cleanup
  public_deleteRepoTag repo_name $repoName tag_name latest proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  set forkFailed
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName forkJson forkFailed err
} -constraints $commonConstraints -result {1}}

###############################################################################
# Fork Tests (repositories-600.x)
###############################################################################

runTest {test repositories-600.0 {fork public repo creates independent copy} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Source: create VM, commit, repo, tag, make public
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set srcRepoName [appendArgs "fork-src-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $srcRepoName "\"\}"] proxy 0

  public_createRepoTag repo_name $srcRepoName json [appendArgs \
      "\{\"tag_name\":\"latest\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  public_setRepositoryVisibility repo_name $srcRepoName \
      json "\{\"is_public\":true\}" proxy 0

  # Fork it
  set forkRepoName [appendArgs "my-fork-" $ts]
  set forkJson [appendArgs \
      "\{\"source_org\":\"test_user\"" \
      ",\"source_repo\":\"" $srcRepoName "\"" \
      ",\"source_tag\":\"latest\"" \
      ",\"repo_name\":\"" $forkRepoName "\"" \
      ",\"tag_name\":\"latest\"\}"]

  set forkResult [public_forkRepository json $forkJson proxy 0]
  set forkVmId [jqRawString $forkResult .vm_id]
  set forkCommitId [jqRawString $forkResult .commit_id]
  set forkReference [jqRawString $forkResult .reference]

  # Verify fork created a new repo with tag
  set forkRepo [public_getRepository repo_name $forkRepoName proxy 0]
  set forkRepoGotName [jqRawString $forkRepo .name]

  set forkTag [public_getRepoTag repo_name $forkRepoName \
      tag_name latest proxy 0]
  set forkTagCommit [jqRawString $forkTag .commit_id]

  # Fork commit should be different from source commit (forker's own)
  set commitDiffers [expr {$forkTagCommit ne $ids(commit)}]

  # Cleanup
  catch { public_deleteVm id $forkVmId proxy 0 }
  public_deleteRepoTag repo_name $forkRepoName tag_name latest proxy 0
  public_deleteRepository repo_name $forkRepoName proxy 0
  public_deleteRepoTag repo_name $srcRepoName tag_name latest proxy 0
  public_deleteRepository repo_name $srcRepoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list [string equal $forkReference [appendArgs $forkRepoName ":latest"]] \
       [string equal $forkRepoGotName $forkRepoName] \
       $commitDiffers \
       [isValidVirtualMachineId $forkVmId]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts srcRepoName forkRepoName forkJson forkResult \
      forkVmId forkCommitId forkReference forkRepo forkRepoGotName \
      forkTag forkTagCommit commitDiffers
} -constraints $commonConstraints -result {True True True True}}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
