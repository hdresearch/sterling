###############################################################################
#
# repositories.eagle --
#
# This file contains end-to-end integration tests for commit repositories
# and the fork feature. Repositories group tagged commits under a named
# image (like Docker's image_name:tag model).
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################
# Repository CRUD Tests (repositories-100.x)
###############################################################################

runTest {test repositories-100.0 {create and get repository} -body {
  set ts [clock seconds]
  set repoName [appendArgs "test-repo-" $ts]

  set createJson [appendArgs \
      "\{\"name\":\"" $repoName \
      "\",\"description\":\"Test repo for repositories-100.0\"\}"]

  set createResult [public_createRepository json $createJson proxy 0]
  set repoId [jqRawString $createResult .repo_id]
  set createdName [jqRawString $createResult .name]

  # Verify we can get it back
  set getResult [public_getRepository repo_name $repoName proxy 0]
  set gotName [jqRawString $getResult .name]
  set gotDescription [jqRawString $getResult .description]
  set gotIsPublic [jq $getResult .is_public]

  # Cleanup
  public_deleteRepository repo_name $repoName proxy 0

  list [string equal $createdName $repoName] \
       [string equal $gotName $repoName] \
       [string equal $gotDescription "Test repo for repositories-100.0"] \
       [string equal $gotIsPublic false]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName createJson createResult repoId createdName \
      getResult gotName gotDescription gotIsPublic
} -constraints $commonConstraints -result {True True True True}}

###############################################################################

runTest {test repositories-100.1 {list repositories} -body {
  set ts [clock seconds]
  set repoName1 [appendArgs "list-repo-a-" $ts]
  set repoName2 [appendArgs "list-repo-b-" $ts]

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName1 "\"\}"] proxy 0

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName2 "\"\}"] proxy 0

  set listResult [public_listRepositories proxy 0]
  set repoNames [jqRawString $listResult {.repositories[].name}]

  set found1 [expr {[string first $repoName1 $repoNames] >= 0}]
  set found2 [expr {[string first $repoName2 $repoNames] >= 0}]

  # Cleanup
  public_deleteRepository repo_name $repoName1 proxy 0
  public_deleteRepository repo_name $repoName2 proxy 0

  list $found1 $found2
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName1 repoName2 listResult repoNames found1 found2
} -constraints $commonConstraints -result {True True}}

###############################################################################

runTest {test repositories-100.2 {delete repository} -body {
  set ts [clock seconds]
  set repoName [appendArgs "delete-repo-" $ts]

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Delete it
  public_deleteRepository repo_name $repoName proxy 0

  # Verify it's gone (should fail with 404)
  set deletedGone [catch {
    public_getRepository repo_name $repoName proxy 0
  } err]

  set deletedGone
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName deletedGone err
} -constraints $commonConstraints -result {1}}

###############################################################################

runTest {test repositories-100.3 {reject duplicate repository name} -body {
  set ts [clock seconds]
  set repoName [appendArgs "dup-repo-" $ts]

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  set duplicateFailed [catch {
    public_createRepository json [appendArgs \
        "\{\"name\":\"" $repoName "\"\}"] proxy 0
  } err]

  # Cleanup
  public_deleteRepository repo_name $repoName proxy 0

  set duplicateFailed
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName duplicateFailed err
} -constraints $commonConstraints -result {1}}

###############################################################################
# Repository Tag Tests (repositories-200.x)
###############################################################################

runTest {test repositories-200.0 {create and get repo tag} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM and commit
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # Create repository
  set ts [clock seconds]
  set repoName [appendArgs "tag-repo-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Create tag in repo
  set tagJson [appendArgs \
      "\{\"tag_name\":\"v1.0\"" \
      ",\"commit_id\":\"" $ids(commit) "\"" \
      ",\"description\":\"First release\"\}"]

  set createResult [public_createRepoTag repo_name $repoName \
      json $tagJson proxy 0]
  set reference [jqRawString $createResult .reference]

  # Get tag back
  set getResult [public_getRepoTag repo_name $repoName \
      tag_name v1.0 proxy 0]
  set gotTagName [jqRawString $getResult .tag_name]
  set gotCommitId [jqRawString $getResult .commit_id]
  set gotDescription [jqRawString $getResult .description]

  # Cleanup
  public_deleteRepoTag repo_name $repoName tag_name v1.0 proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list [string equal $reference [appendArgs $repoName ":v1.0"]] \
       [string equal $gotTagName "v1.0"] \
       [string equal $gotCommitId $ids(commit)] \
       [string equal $gotDescription "First release"]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName tagJson createResult reference \
      getResult gotTagName gotCommitId gotDescription
} -constraints $commonConstraints -result {True True True True}}

###############################################################################

runTest {test repositories-200.1 {list and delete repo tags} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set repoName [appendArgs "list-tags-repo-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Create two tags
  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"latest\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"stable\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  # List tags
  set listResult [public_listRepoTags repo_name $repoName proxy 0]
  set tagCount [jq $listResult {.tags | length}]

  # Delete one tag
  public_deleteRepoTag repo_name $repoName tag_name latest proxy 0

  set listResult2 [public_listRepoTags repo_name $repoName proxy 0]
  set tagCount2 [jq $listResult2 {.tags | length}]

  # Cleanup
  public_deleteRepoTag repo_name $repoName tag_name stable proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list [expr {$tagCount == 2}] [expr {$tagCount2 == 1}]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName listResult tagCount listResult2 tagCount2
} -constraints $commonConstraints -result {True True}}

###############################################################################

runTest {test repositories-200.2 {update repo tag to new commit} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit1) [public_commitVm id $ids(vm) proxy 0]
  set ids(commit2) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set repoName [appendArgs "update-tag-repo-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Create tag pointing to first commit
  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"latest\",\"commit_id\":\"" $ids(commit1) "\"\}"] \
      proxy 0

  # Verify initial commit
  set getResult1 [public_getRepoTag repo_name $repoName \
      tag_name latest proxy 0]
  set initialCommitId [jqRawString $getResult1 .commit_id]

  # Update tag to second commit
  public_updateRepoTag repo_name $repoName tag_name latest \
      json [appendArgs "\{\"commit_id\":\"" $ids(commit2) "\"\}"] proxy 0

  # Verify updated
  set getResult2 [public_getRepoTag repo_name $repoName \
      tag_name latest proxy 0]
  set updatedCommitId [jqRawString $getResult2 .commit_id]

  # Cleanup
  public_deleteRepoTag repo_name $repoName tag_name latest proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list [string equal $initialCommitId $ids(commit1)] \
       [string equal $updatedCommitId $ids(commit2)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName getResult1 getResult2 \
      initialCommitId updatedCommitId
} -constraints $commonConstraints -result {True True}}

###############################################################################
# Public Repository Tests (repositories-300.x)
###############################################################################

runTest {test repositories-300.0 {make repo public and browse unauthenticated} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set repoName [appendArgs "public-repo-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Tag a commit
  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"v1.0\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  # Make public
  public_setRepositoryVisibility repo_name $repoName \
      json "\{\"is_public\":true\}" proxy 0

  # Verify it appears in public listing
  set publicList [public_listPublicRepositories proxy 0]
  set publicNames [jqRawString $publicList {.repositories[].name}]
  set foundInPublic [expr {[string first $repoName $publicNames] >= 0}]

  # Get public repo by org/name
  # NOTE: org name comes from seed data
  set publicRepo [public_getPublicRepository \
      org_name test_user repo_name $repoName proxy 0]
  set publicFullName [jqRawString $publicRepo .full_name]

  # List public tags
  set publicTags [public_listPublicRepoTags \
      org_name test_user repo_name $repoName proxy 0]
  set publicTagCount [jq $publicTags {.tags | length}]

  # Get specific public tag
  set publicTag [public_getPublicRepoTag \
      org_name test_user repo_name $repoName tag_name v1.0 proxy 0]
  set publicTagCommit [jqRawString $publicTag .commit_id]

  # Cleanup
  public_deleteRepoTag repo_name $repoName tag_name v1.0 proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list $foundInPublic \
       [string equal $publicFullName [appendArgs "test_user/" $repoName]] \
       [expr {$publicTagCount == 1}] \
       [string equal $publicTagCommit $ids(commit)]
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName publicList publicNames foundInPublic \
      publicRepo publicFullName publicTags publicTagCount publicTag \
      publicTagCommit
} -constraints $commonConstraints -result {True True True True}}

###############################################################################

runTest {test repositories-300.1 {private repo not visible in public listing} -body {
  set ts [clock seconds]
  set repoName [appendArgs "private-repo-" $ts]

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Should NOT appear in public listing
  set publicList [public_listPublicRepositories proxy 0]
  set publicNames [jqRawString $publicList {.repositories[].name}]
  set notFound [expr {[string first $repoName $publicNames] < 0}]

  # Should NOT be accessible via public get
  set publicGetFailed [catch {
    public_getPublicRepository \
        org_name test_user repo_name $repoName proxy 0
  } err]

  # Cleanup
  public_deleteRepository repo_name $repoName proxy 0

  list $notFound $publicGetFailed
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName publicList publicNames notFound \
      publicGetFailed err
} -constraints $commonConstraints -result {True 1}}

###############################################################################

runTest {test repositories-300.2 {revoke public visibility} -body {
  set ts [clock seconds]
  set repoName [appendArgs "revoke-repo-" $ts]

  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  # Make public
  public_setRepositoryVisibility repo_name $repoName \
      json "\{\"is_public\":true\}" proxy 0

  # Verify accessible
  public_getPublicRepository \
      org_name test_user repo_name $repoName proxy 0

  # Revoke
  public_setRepositoryVisibility repo_name $repoName \
      json "\{\"is_public\":false\}" proxy 0

  # Should no longer be accessible
  set revokedGone [catch {
    public_getPublicRepository \
        org_name test_user repo_name $repoName proxy 0
  } err]

  # But still accessible via private route
  set privateOk [catch {
    public_getRepository repo_name $repoName proxy 0
  } err2]

  # Cleanup
  public_deleteRepository repo_name $repoName proxy 0

  list $revokedGone [expr {$privateOk == 0}]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain ts repoName revokedGone err privateOk err2
} -constraints $commonConstraints -result {1 True}}

###############################################################################
# Branch by Ref Tests (repositories-400.x)
###############################################################################

runTest {test repositories-400.0 {branch VM by repo ref} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create VM, commit, repo, and tag
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set ts [clock seconds]
  set repoName [appendArgs "branch-ref-repo-" $ts]
  public_createRepository json [appendArgs \
      "\{\"name\":\"" $repoName "\"\}"] proxy 0

  public_createRepoTag repo_name $repoName json [appendArgs \
      "\{\"tag_name\":\"latest\",\"commit_id\":\"" $ids(commit) "\"\}"] \
      proxy 0

  # Use from_commit with "ref" format (repo_name:tag_name)
  set refJson [appendArgs "\{\"ref\":\"" $repoName ":latest\"\}"]
  set ids(fromRef) [public_resumeVmByTag json $refJson proxy 0]

  set fromRefValid [isValidVirtualMachineId $ids(fromRef)]

  # Cleanup
  catch { public_deleteVm id $ids(fromRef) proxy 0 }
  public_deleteRepoTag repo_name $repoName tag_name latest proxy 0
  public_deleteRepository repo_name $repoName proxy 0
  public_deleteVm id $ids(vm) proxy 0

  set fromRefValid
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ts repoName refJson fromRefValid
} -constraints $commonConstraints -result {True}}

