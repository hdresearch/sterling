###############################################################################
#
# list_parent_commits.eagle --
#
# This file contains end-to-end integration tests for the list parent commits
# feature. This feature retrieves the complete ancestry chain of a commit.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################
# Basic List Parent Commits Tests (list-commits-100.x)
###############################################################################

runTest {test list-commits-100.0 {list parent commits for single commit} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM and commit it
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # List parent commits for this commit
  set result [public_listParentCommits id $ids(commit) proxy 0]

  # Should return at least one commit (the commit itself)
  set commitCount [jq $result {. | length}]

  # Cleanup
  public_deleteVm id $ids(vm) proxy 0

  expr {$commitCount >= 1}
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids result commitCount
} -constraints $commonConstraints -result {True}}

###############################################################################

runTest {test list-commits-101.0 {list parent commits shows ancestry chain} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM
  set ids(vm1) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  # First commit
  set ids(commit1) [public_commitVm id $ids(vm1) proxy 0]

  # Delete original VM
  public_deleteVm id $ids(vm1) proxy 0

  # Resume from first commit to create second VM
  set commit_id $ids(commit1)
  set ids(vm2) [public_resumeVm id $ids(commit1) json [processJsonTemplate \
      public [getJsonTemplate public resumeVm]] proxy 0]

  # Second commit (child of first)
  set ids(commit2) [public_commitVm id $ids(vm2) proxy 0]

  # List parent commits starting from second commit
  set result [public_listParentCommits id $ids(commit2) proxy 0]

  # Should show ancestry: commit2 -> commit1
  set commitCount [jq $result {. | length}]

  # Verify both commits are in the chain
  set commitIds [jqRawString $result {.[].id}]
  set hasCommit1 [expr {[string first $ids(commit1) $commitIds] >= 0}]
  set hasCommit2 [expr {[string first $ids(commit2) $commitIds] >= 0}]

  # Cleanup
  public_deleteVm id $ids(vm2) proxy 0

  list [expr {$commitCount >= 2}] $hasCommit1 $hasCommit2
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids result commitCount commitIds hasCommit1 hasCommit2
} -constraints $commonConstraints -result {True True True}}

###############################################################################

runTest {test list-commits-102.0 {list parent commits with three generations} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create first VM and commit
  set ids(vm1) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]
  set ids(commit1) [public_commitVm id $ids(vm1) proxy 0]
  public_deleteVm id $ids(vm1) proxy 0

  # Resume from first commit, create second commit
  set commit_id $ids(commit1)
  set ids(vm2) [public_resumeVm id $ids(commit1) json [processJsonTemplate \
      public [getJsonTemplate public resumeVm]] proxy 0]
  set ids(commit2) [public_commitVm id $ids(vm2) proxy 0]
  public_deleteVm id $ids(vm2) proxy 0

  # Resume from second commit, create third commit
  set commit_id $ids(commit2)
  set ids(vm3) [public_resumeVm id $ids(commit2) json [processJsonTemplate \
      public [getJsonTemplate public resumeVm]] proxy 0]
  set ids(commit3) [public_commitVm id $ids(vm3) proxy 0]

  # List parent commits starting from third commit
  set result [public_listParentCommits id $ids(commit3) proxy 0]

  # Should show full ancestry: commit3 -> commit2 -> commit1
  set commitCount [jq $result {. | length}]

  # Verify all three commits are in the chain
  set commitIds [jqRawString $result {.[].id}]
  set hasCommit1 [expr {[string first $ids(commit1) $commitIds] >= 0}]
  set hasCommit2 [expr {[string first $ids(commit2) $commitIds] >= 0}]
  set hasCommit3 [expr {[string first $ids(commit3) $commitIds] >= 0}]

  # Cleanup
  public_deleteVm id $ids(vm3) proxy 0

  list [expr {$commitCount >= 3}] $hasCommit1 $hasCommit2 $hasCommit3
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids result commitCount commitIds hasCommit1 hasCommit2 hasCommit3
} -constraints $commonConstraints -result {True True True True}}

###############################################################################

runTest {test list-commits-103.0 {list parent commits returns commit metadata} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM and commit
  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  # List parent commits
  set result [public_listParentCommits id $ids(commit) proxy 0]

  # Verify commit has expected fields
  set firstCommit [jq $result {.[0]}]
  set hasId [expr {[jqRawString $firstCommit .id] ne "null"}]
  set hasOwnerId [expr {[jqRawString $firstCommit .owner_id] ne "null"}]
  set hasCreatedAt [expr {[jqRawString $firstCommit .created_at] ne "null"}]

  # Cleanup
  public_deleteVm id $ids(vm) proxy 0

  list $hasId $hasOwnerId $hasCreatedAt
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids result firstCommit hasId hasOwnerId hasCreatedAt
} -constraints $commonConstraints -result {True True True}}

###############################################################################
# Error Handling Tests (list-commits-200.x)
###############################################################################

runTest {test list-commits-200.0 {list parent commits for non-existent commit} -body {
  # Use a random UUID that doesn't exist
  set fakeCommitId "00000000-0000-0000-0000-000000000000"

  set code [catch {
    public_listParentCommits id $fakeCommitId proxy 0
  } result]

  list $code [string match -nocase "*not found*" $result]
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain fakeCommitId code result
} -constraints $commonConstraints -result {1 True}}

###############################################################################

runTest {test list-commits-201.0 {list parent commits with invalid UUID format} -body {
  set invalidId "not-a-valid-uuid"

  set code [catch {
    public_listParentCommits id $invalidId proxy 0
  } result]

  # Should fail (either validation error or bad request)
  expr {$code != 0}
} -cleanup {
  catch {info previouspid true}

  unset -nocomplain invalidId code result
} -constraints $commonConstraints -result {True}}

###############################################################################
# Branch and Commit Ancestry Tests (list-commits-300.x)
###############################################################################

runTest {test list-commits-300.0 {branched VMs share common ancestor} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  # Create a VM and commit (this will be the common ancestor)
  set ids(vm1) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]
  set ids(baseCommit) [public_commitVm id $ids(vm1) proxy 0]

  # Branch twice from the same commit
  set ids(branchVm1) [public_branchByCommit id $ids(baseCommit) json \
      [processJsonTemplate public [getJsonTemplate public branchByCommit]] proxy 0]
  set ids(branchCommit1) [public_commitVm id $ids(branchVm1) proxy 0]

  set ids(branchVm2) [public_branchByCommit id $ids(baseCommit) json \
      [processJsonTemplate public [getJsonTemplate public branchByCommit]] proxy 0]
  set ids(branchCommit2) [public_commitVm id $ids(branchVm2) proxy 0]

  # Get ancestry for both branch commits
  set ancestry1 [public_listParentCommits id $ids(branchCommit1) proxy 0]
  set ancestry2 [public_listParentCommits id $ids(branchCommit2) proxy 0]

  # Both should include the base commit in their ancestry
  set ancestry1Ids [jqRawString $ancestry1 {.[].id}]
  set ancestry2Ids [jqRawString $ancestry2 {.[].id}]

  set branch1HasBase [expr {[string first $ids(baseCommit) $ancestry1Ids] >= 0}]
  set branch2HasBase [expr {[string first $ids(baseCommit) $ancestry2Ids] >= 0}]

  # Cleanup
  catch { public_deleteVm id $ids(branchVm1) proxy 0 }
  catch { public_deleteVm id $ids(branchVm2) proxy 0 }
  public_deleteVm id $ids(vm1) proxy 0

  list $branch1HasBase $branch2HasBase
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids ancestry1 ancestry2 ancestry1Ids ancestry2Ids \
      branch1HasBase branch2HasBase
} -constraints $commonConstraints -result {True True}}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
