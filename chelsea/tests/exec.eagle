###############################################################################
#
# exec.eagle --
#
# This file contains end-to-end integration tests for the exec API endpoint,
# including TTY support.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

#
# NOTE: Check test constraints specific to tests in this file that do not
#       require any plugins to be loaded.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################

runTest {test exec-100.0 {basic exec without TTY} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  # Execute a simple command
  set command {["echo", "hello"]}
  set tty false
  set execResult [internal_execVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal execVm]]]

  set exitCode [jqRawString $execResult .exit_code]
  set stdout [jqRawString $execResult .stdout]

  internal_deleteVm id $ids(1)

  if {$exitCode ne "0"} then {
    error [appendArgs "expected exit code 0, got: " $exitCode]
  }

  if {![string match "*hello*" $stdout]} then {
    error [appendArgs "expected stdout to contain 'hello', got: " $stdout]
  }
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command tty execResult exitCode stdout
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test exec-101.0 {exec with TTY - isatty returns true} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  # Execute python to check isatty() - should return True with TTY
  set command {["python3", "-c", "import sys; print(sys.stdout.isatty())"]}
  set tty true
  set execResult [internal_execVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal execVm]]]

  set exitCode [jqRawString $execResult .exit_code]
  set stdout [jqRawString $execResult .stdout]

  internal_deleteVm id $ids(1)

  if {$exitCode ne "0"} then {
    error [appendArgs "expected exit code 0, got: " $exitCode]
  }

  if {![string match "*True*" $stdout]} then {
    error [appendArgs "expected isatty() to return True with TTY, got: " $stdout]
  }
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command tty execResult exitCode stdout
} -constraints [concat $commonConstraints [list knownBug]] -result {}}

###############################################################################

