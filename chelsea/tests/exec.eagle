      internal [getJsonTemplate internal execVm]]]

  set exitCode [jqRawString $execResult .exit_code]

  internal_deleteVm id $ids(1)

  if {$exitCode ne "42"} then {
    error [appendArgs "expected exit code 42, got: " $exitCode]
  }
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command tty execResult exitCode
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test exec-106.0 {exec captures stderr} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  # Execute a command that writes to stderr
  set command {["sh", "-c", "echo error_message >&2"]}
  set tty false
  set execResult [internal_execVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal execVm]]]

  set exitCode [jqRawString $execResult .exit_code]
  set stderr [jqRawString $execResult .stderr]

  internal_deleteVm id $ids(1)

  if {$exitCode ne "0"} then {
    error [appendArgs "expected exit code 0, got: " $exitCode]
  }

  if {![string match "*error_message*" $stderr]} then {
    error [appendArgs "expected stderr to contain 'error_message', got: " $stderr]
  }
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command tty execResult exitCode stderr
} -constraints $commonConstraints -result {}}

###############################################################################

###############################################################################

runTest {test exec-107.0 {exec then retrieve logs (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  # Execute a command that writes to both stdout and stderr
  set command {["sh", "-c", "echo log_stdout; echo log_stderr >&2"]}
  set tty false
  set execResult [internal_execVm id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal execVm]]]

  set exitCode [jqRawString $execResult .exit_code]

  if {$exitCode ne "0"} then {
    error [appendArgs "expected exit code 0, got: " $exitCode]
  }

  # Retrieve exec logs
  set logsResult [internal_execVmLogs id $ids(1)]

  # Verify the response is valid JSON with an entries array
  set entriesLen [jq $logsResult {.entries | length}]

  if {$entriesLen < 1} then {
    error [appendArgs "expected at least 1 log entry, got: " $entriesLen]
  }

  set _ [internal_deleteVm id $ids(1)]
  return ""
  set _ ""
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command tty execResult exitCode logsResult entriesLen _
} -constraints $commonConstraints -result {}}

###############################################################################

runTest {test exec-108.0 {streaming exec returns NDJSON (internal)} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(1) [internal_newVm json [processJsonTemplate \
      internal [getJsonTemplate internal newVm]]]

  # Execute a command via streaming exec
  set command {["echo", "stream_test"]}
  set streamResult [internal_execVmStream id $ids(1) json [processJsonTemplate \
      internal [getJsonTemplate internal execVmStream]]]

  set sawData false
  set sawExit false

  foreach line [split [string trim $streamResult] \n] {
    set trimmed [string trim $line]
    if {$trimmed eq ""} then {
      continue
    }

    set entryType [jqRawString $trimmed .type]

    if {$entryType eq "chunk"} then {
      set decoded [jqRawString $trimmed {.data_b64 | @base64d}]
      if {[string match "*stream_test*" $decoded]} then {
        set sawData true
      }
    } elseif {$entryType eq "exit"} then {
      set sawExit true
    }
  }

  if {!$sawData} then {
    error [appendArgs \
        "expected streaming output to contain 'stream_test', got: " \
        $streamResult]
  }

  if {!$sawExit} then {
    error [appendArgs \
        "expected streaming output to contain exit event, got: " \
        $streamResult]
  }

  set _ [internal_deleteVm id $ids(1)]
  return ""
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids command streamResult sawData sawExit _
} -constraints $commonConstraints -result {}}

###############################################################################

foreach proxy [list 0 1] {
  runTest [string map [list %proxy% $proxy] \
      {test exec-200.%proxy% {exec via public API without TTY} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # Execute a simple command
    set command {["echo", "public_test"]}
    set tty false
    set execResult [public_execVm id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public execVm]] proxy %proxy%]

    set exitCode [jqRawString $execResult .exit_code]
    set stdout [jqRawString $execResult .stdout]

    set _ [public_deleteVm id $ids(1) proxy %proxy%]
    set _ ""

    if {$exitCode ne "0"} then {
      error [appendArgs "expected exit code 0, got: " $exitCode]
    }

    if {![string match "*public_test*" $stdout]} then {
      error [appendArgs "expected stdout to contain 'public_test', got: " $stdout]
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids command tty execResult exitCode stdout
      } -constraints [concat $commonConstraints [list knownBug]] -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test exec-201.%proxy% {exec via public API with TTY} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # Execute python to check isatty()
    set command {["python3", "-c", "import sys; print(sys.stdout.isatty())"]}
    set tty true
    set execResult [public_execVm id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public execVm]] proxy %proxy%]

    set exitCode [jqRawString $execResult .exit_code]
    set stdout [jqRawString $execResult .stdout]

    set _ [public_deleteVm id $ids(1) proxy %proxy%]
    return ""

    if {$exitCode ne "0"} then {
      error [appendArgs "expected exit code 0, got: " $exitCode]
    }

    if {![string match "*True*" $stdout]} then {
      error [appendArgs "expected isatty() to return True with TTY, got: " $stdout]
    }
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids command tty execResult exitCode stdout
  } -constraints $commonConstraints -result {}}]
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test exec-202.%proxy% {exec then retrieve logs (public)} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # Execute a command
    set command {["echo", "public_log_test"]}
    set tty false
    set execResult [public_execVm id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public execVm]] proxy %proxy%]

    set exitCode [jqRawString $execResult .exit_code]

    if {$exitCode ne "0"} then {
      error [appendArgs "expected exit code 0, got: " $exitCode]
    }

    # Retrieve exec logs via the public logs endpoint
    set logsResult [public_execVmLogs id $ids(1) proxy %proxy%]

    set entriesLen [jq $logsResult {.entries | length}]

    if {$entriesLen < 1} then {
      error [appendArgs "expected at least 1 log entry, got: " $entriesLen]
    }

    set _ [public_deleteVm id $ids(1) proxy %proxy%]
    set _ ""
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids command tty execResult exitCode logsResult entriesLen _
  } -constraints $commonConstraints -result {}}]

  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test exec-203.%proxy% {streaming exec via public API} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set ids(1) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # Execute a command via streaming exec
    set command {["echo", "public_stream_test"]}
    set streamResult [public_execVmStream id $ids(1) json [processJsonTemplate \
        public [getJsonTemplate public execVmStream]] proxy %proxy%]

    set sawData false
    set sawExit false

    foreach line [split [string trim $streamResult] \n] {
      set trimmed [string trim $line]
      if {$trimmed eq ""} then {
        continue
      }

      set entryType [jqRawString $trimmed .type]

      if {$entryType eq "chunk"} then {
        set decoded [jqRawString $trimmed {.data_b64 | @base64d}]
        if {[string match "*public_stream_test*" $decoded]} then {
          set sawData true
        }
      } elseif {$entryType eq "exit"} then {
        set sawExit true
      }
    }

    if {!$sawData} then {
      error [appendArgs \
          "expected streaming output to contain 'public_stream_test', got: " \
          $streamResult]
    }

    if {!$sawExit} then {
      error [appendArgs \
          "expected streaming output to contain exit event, got: " \
          $streamResult]
    }

    set _ [public_deleteVm id $ids(1) proxy %proxy%]
    set _ ""
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids command streamResult sawData sawExit _
  } -constraints $commonConstraints -result {}}]
}; unset -nocomplain proxy

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
