###############################################################################
#
# commits.eagle --
#
# End-to-end integration tests for commit listing and deletion via the public
# API. Covers happy paths and conflict/error scenarios for commit deletion.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

catch {info previouspid true}

###############################################################################

#
# NOTE: Check test constraints specific to this suite.
#
if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################
# Commit Listing Tests (commits-100.x)
###############################################################################

runTest {test commits-100.0 {list commits includes freshly created commit} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set listJson [public_listCommits proxy 0 limit 100 offset 0]
  set commitIds [jqRawString $listJson {.commits[].commit_id}]
  set totalCount [expr {int([jq $listJson {.total}])}]

  set containsCommit [expr {[string first $ids(commit) $commitIds] >= 0}]
  set hasTotal [expr {$totalCount >= 1}]

  public_deleteCommit id $ids(commit) proxy 0
  public_deleteVm id $ids(vm) proxy 0

  list $containsCommit $hasTotal
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids listJson commitIds totalCount containsCommit hasTotal
} -constraints $commonConstraints -result {True True}}

###############################################################################
# Commit Deletion Success (commits-101.x)
###############################################################################

runTest {test commits-101.0 {delete commit removes it from list results} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set beforeJson [public_listCommits proxy 0 limit 100 offset 0]
  set beforeIds [jqRawString $beforeJson {.commits[].commit_id}]
  set presentBefore [expr {[string first $ids(commit) $beforeIds] >= 0}]

  public_deleteCommit id $ids(commit) proxy 0

  set afterJson [public_listCommits proxy 0 limit 100 offset 0]
  set afterIds [jqRawString $afterJson {.commits[].commit_id}]
  set missingAfter [expr {[string first $ids(commit) $afterIds] == -1}]

  public_deleteVm id $ids(vm) proxy 0

  list $presentBefore $missingAfter
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids beforeJson beforeIds presentBefore afterJson \
      afterIds missingAfter
} -constraints $commonConstraints -result {True True}}

###############################################################################
# Commit Deletion Conflicts (commits-102.x)
###############################################################################

runTest {test commits-102.0 {delete commit fails when descendant VM exists} -body {
  setupJsonTemplateVariables
  setupWireGuardJsonTemplateVariables

  set ids(vm) [public_newVm json [processJsonTemplate \
      public [getJsonTemplate public newVm]] proxy 0]

  set ids(commit) [public_commitVm id $ids(vm) proxy 0]

  set commit_id $ids(commit)
  set ids(resumed) [public_resumeVm id $ids(commit) json \
      [processJsonTemplate public [getJsonTemplate public resumeVm]] proxy 0]

  set code [catch {
    public_deleteCommit id $ids(commit) proxy 0
  } result]

  set raisedConflict [expr {
    $code != 0 && [string match -nocase "*active vm*" $result]
  }]

  catch { public_deleteVm id $ids(resumed) proxy 0 }
  catch { public_deleteVm id $ids(vm) proxy 0 }
  catch { public_deleteCommit id $ids(commit) proxy 0 }

  list [expr {$code != 0}] $raisedConflict
} -cleanup {
  cleanupWireGuardJsonTemplateVariables
  cleanupJsonTemplateVariables

  catch {info previouspid true}

  unset -nocomplain ids commit_id code result raisedConflict
} -constraints $commonConstraints -result {True True}}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
