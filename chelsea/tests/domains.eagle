###############################################################################
#
# domains.eagle --
#
# This file contains end-to-end integration tests for the custom domain
# CRUD API endpoints.
#
###############################################################################

package require Eagle
package require Eagle.Test
runTestPrologue

###############################################################################

package require Chelsea.Meta

###############################################################################

maybeCreateTemporaryDirectory
maybeUseTemporaryDirectory
maybeLoadTestSettings

###############################################################################

if {[info exists exeFile] && \
    ![haveConstraint [appendArgs file_ [file tail $exeFile]]]} then {
  checkForFile $test_channel $exeFile
}

###############################################################################

if {[info exists wireGuardFile] && \
    [hasRuntimeOption remoteChelsea]} then {
  writeFile $wireGuardFile ""; # TODO: Fix me.
  wgQuickUp $test_channel $wireGuardFile
}

###############################################################################

foreach proxy [list 0 1] {

  #############################################################################
  # Test: Create a domain, verify it, then delete it
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-100.%proxy% {create and delete a custom domain} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Create a VM first (domains must be attached to a VM)
    set ids(vm) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # 2. Create a domain attached to the VM
    set domain "test-domain-100-%proxy%.example.com"
    set vm_id $ids(vm)

    set domainJson [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain) [jqRawString $domainJson .domain_id]

    if {![isValidDomainId $ids(domain)]} then {
      error [appendArgs "bad domain_id: " $domainJson]
    }

    # 3. Verify the domain name is returned correctly
    set returnedDomain [jqRawString $domainJson .domain]

    if {$returnedDomain ne $domain} then {
      error [appendArgs "domain mismatch: have \"" $returnedDomain \
          "\", want \"" $domain \"]
    }

    # 4. Verify vm_id is returned correctly
    set returnedVmId [jqRawString $domainJson .vm_id]

    if {$returnedVmId ne $ids(vm)} then {
      error [appendArgs "vm_id mismatch: have \"" $returnedVmId \
          "\", want \"" $ids(vm) \"]
    }

    # 5. Delete the domain
    public_deleteDomain id $ids(domain) proxy %proxy%

    # 6. Clean up VM
    public_deleteVm id $ids(vm) proxy %proxy%

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids domainJson domain vm_id returnedDomain returnedVmId
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: Get a specific domain by ID
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-101.%proxy% {get a custom domain by ID} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Create a VM
    set ids(vm) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # 2. Create a domain
    set domain "test-domain-101-%proxy%.example.com"
    set vm_id $ids(vm)

    set domainJson [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain) [jqRawString $domainJson .domain_id]

    # 3. Get the domain by ID
    set getJson [public_getDomain id $ids(domain) proxy %proxy%]

    set getDomainName [jqRawString $getJson .domain]
    set getVmId [jqRawString $getJson .vm_id]
    set getDomainId [jqRawString $getJson .domain_id]

    if {$getDomainName ne $domain} then {
      error [appendArgs "domain name mismatch: have \"" $getDomainName \
          "\", want \"" $domain \"]
    }

    if {$getVmId ne $ids(vm)} then {
      error [appendArgs "vm_id mismatch: have \"" $getVmId \
          "\", want \"" $ids(vm) \"]
    }

    if {$getDomainId ne $ids(domain)} then {
      error [appendArgs "domain_id mismatch: have \"" $getDomainId \
          "\", want \"" $ids(domain) \"]
    }

    # 4. Cleanup
    public_deleteDomain id $ids(domain) proxy %proxy%
    public_deleteVm id $ids(vm) proxy %proxy%

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids domainJson getJson domain vm_id \
        getDomainName getVmId getDomainId
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: List domains (all and filtered by VM)
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-102.%proxy% {list domains with and without vm_id filter} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Create a VM
    set ids(vm) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # 2. Create two domains
    set domain "test-domain-102a-%proxy%.example.com"
    set vm_id $ids(vm)

    set domainJson1 [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain1) [jqRawString $domainJson1 .domain_id]

    set domain "test-domain-102b-%proxy%.example.com"

    set domainJson2 [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain2) [jqRawString $domainJson2 .domain_id]

    # 3. List all domains (should contain at least 2)
    set listJson [public_listDomains proxy %proxy%]
    set listLength [jqRawString $listJson {. | length}]

    if {$listLength < 2} then {
      error [appendArgs "expected at least 2 domains, got: " $listLength]
    }

    # 4. List domains filtered by VM ID
    set filteredJson [public_listDomains proxy %proxy% \
        parameters [list vm_id $ids(vm)]]
    set filteredLength [jqRawString $filteredJson {. | length}]

    if {$filteredLength < 2} then {
      error [appendArgs \
          "expected at least 2 domains for VM, got: " $filteredLength]
    }

    # 5. Cleanup
    public_deleteDomain id $ids(domain1) proxy %proxy%
    public_deleteDomain id $ids(domain2) proxy %proxy%
    public_deleteVm id $ids(vm) proxy %proxy%

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids domainJson1 domainJson2 domain vm_id \
        listJson listLength filteredJson filteredLength
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: Domain case insensitivity (RFC 1035)
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-103.%proxy% {domain names are case-insensitive} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Create a VM
    set ids(vm) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # 2. Create a domain with mixed case
    set domain "Test-Domain-103-%proxy%.Example.COM"
    set vm_id $ids(vm)

    set domainJson [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain) [jqRawString $domainJson .domain_id]

    # 3. Verify it was stored in lowercase
    set storedDomain [jqRawString $domainJson .domain]

    if {$storedDomain ne [string tolower $domain]} then {
      error [appendArgs "domain should be lowercase: have \"" \
          $storedDomain "\", want \"" [string tolower $domain] \"]
    }

    # 4. Cleanup
    public_deleteDomain id $ids(domain) proxy %proxy%
    public_deleteVm id $ids(vm) proxy %proxy%

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids domainJson domain vm_id storedDomain
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: Duplicate domain returns 409 Conflict
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-104.%proxy% {duplicate domain returns conflict error} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Create a VM
    set ids(vm) [public_newVm json [processJsonTemplate \
        public [getJsonTemplate public newVm]] proxy %proxy%]

    # 2. Create a domain
    set domain "test-domain-104-%proxy%.example.com"
    set vm_id $ids(vm)

    set domainJson [public_createDomain \
        json [processJsonTemplate public [getJsonTemplate public createDomain]] \
        proxy %proxy%]

    set ids(domain) [jqRawString $domainJson .domain_id]

    # 3. Try to create the same domain again - should fail
    set code [catch {
      public_createDomain \
          json [processJsonTemplate public [getJsonTemplate public createDomain]] \
          proxy %proxy%
    } result]

    if {$code == 0} then {
      error "expected duplicate domain creation to fail"
    }

    # 4. Verify it was a 409 conflict
    if {![string match "*409*" $result]} then {
      error [appendArgs "expected 409 conflict, got: " $result]
    }

    # 5. Cleanup
    public_deleteDomain id $ids(domain) proxy %proxy%
    public_deleteVm id $ids(vm) proxy %proxy%

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain ids domainJson domain vm_id code result
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: Delete domain is idempotent (deleting deleted domain returns 404)
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-105.%proxy% {delete non-existent domain returns not found} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    # 1. Try to delete a domain that doesn't exist (use a large fake ID)
    set code [catch {
      public_deleteDomain id 0b181903-3230-42e3-a899-dd44575e78fb proxy %proxy%
    } result]

    if {$code == 0} then {
      error "expected deleting non-existent domain to fail"
    }

    # 2. Verify it was a 404 not found
    if {![string match "*404*" $result]} then {
      error [appendArgs "expected 404 not found, got: " $result]
    }

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain code result
  } -constraints $commonConstraints -result {ok}}]

  #############################################################################
  # Test: Get non-existent domain returns 404
  #############################################################################

  runTest [string map [list %proxy% $proxy] \
      {test domains-106.%proxy% {get non-existent domain returns not found} -body {
    setupJsonTemplateVariables
    setupWireGuardJsonTemplateVariables

    set code [catch {
      public_getDomain id 08e4af6b-98de-4c00-ba6c-8f9478356328 proxy %proxy%
    } result]

    if {$code == 0} then {
      error "expected getting non-existent domain to fail"
    }

    if {![string match "*404*" $result]} then {
      error [appendArgs "expected 404 not found, got: " $result]
    }

    list ok
  } -cleanup {
    cleanupWireGuardJsonTemplateVariables
    cleanupJsonTemplateVariables

    catch {info previouspid true}

    unset -nocomplain code result
  } -constraints $commonConstraints -result {ok}}]

}; unset -nocomplain proxy

###############################################################################

if {[hasRuntimeOption remoteChelsea]} then {
  wgQuickDown $test_channel $wireGuardFile
  catch {file delete $wireGuardFile}
}

###############################################################################

cleanupTestSettings
maybeDeleteTemporaryDirectory

###############################################################################

runTestEpilogue
