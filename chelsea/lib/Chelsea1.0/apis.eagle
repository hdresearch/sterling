###############################################################################
#
# apis.eagle --
#
###############################################################################

#
# NOTE: Use our own namespace here because even though we may not directly
#       support namespaces ourselves, we do not want to pollute the global
#       namespace if this script actually ends up being evaluated in Tcl.
#
namespace eval ::Chelsea {
  nproc public_version { proxy } {
    set response [makeApiCall type public name version proxy $proxy]
    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_sshKey { id proxy } {
    set response [makeApiCall type public name sshKey id $id proxy $proxy]
    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    set port [jqRawString $stdOut .ssh_port]

    if {![isValidPort $port]} then {
      error [appendArgs "bad SSH port number: " $stdOut]
    }

    set privateKey [jqRawString $stdOut .ssh_private_key]

    if {![stringIsSshPrivateKey $privateKey]} then {
      error [appendArgs "bad SSH private key: " $stdOut]
    }

    return [list port $port privateKey $privateKey]
  }

  nproc public_newVm { json proxy } {
    # Try the VM pool first (transparent — returns "" if pool disabled)
    set poolId [pool_claim public]

    if {[string length $poolId] > 0} then {
      return $poolId
    }

    set response [makeApiCall \
        type public name newVm json $json proxy $proxy parameters [list \
        wait_boot true]]

    verifyHttpResponseCode $response 201

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    set id [jqRawString $stdOut .vm_id]

    if {![isValidVirtualMachineId $id]} then {
      error [appendArgs "bad virtual machine identifier: " $stdOut]
    }

    return $id
  }

  nproc public_commitVm { id proxy } {
    set response [makeApiCall type public name commitVm id $id proxy $proxy]
    verifyHttpResponseCode $response 201

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    set id [jqRawString $stdOut .commit_id]

    if {![isValidCommitId $id]} {
      error [appendArgs "bad commit identifier: " $stdOut]
    }

    return $id
  }

