  nproc public_createDomain { json proxy } {
    set response [makeApiCall \
        type public name createDomain json $json proxy $proxy]

    verifyHttpResponseCode $response 201

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    set domainId [jqRawString $stdOut .domain_id]

    if {![isValidDomainId $domainId]} then {
      error [appendArgs "bad domain identifier: " $stdOut]
    }

    return $stdOut
  }

  nproc public_listDomains { proxy {parameters ""} } {
    set response [makeApiCall \
        type public name listDomains proxy $proxy parameters $parameters]

    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_getDomain { id proxy } {
    if {$proxy} then {
      global proxyApiHost
      set baseUri $proxyApiHost
    } else {
      global publicApiHost
      set baseUri $publicApiHost
    }

    global headerHost
    set host $headerHost
    set apiKey [extractTestApiKey]

    set response [execApiCurlCommand \
        baseUri $baseUri host $host apiKey $apiKey method GET \
        path [appendArgs /api/v1/domains/ $id]]

    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_deleteDomain { id proxy } {
    if {$proxy} then {
      global proxyApiHost
      set baseUri $proxyApiHost
    } else {
      global publicApiHost
      set baseUri $publicApiHost
    }

    global headerHost
    set host $headerHost
    set apiKey [extractTestApiKey]

    set response [execApiCurlCommand \
        baseUri $baseUri host $host apiKey $apiKey method DELETE \
        path [appendArgs /api/v1/domains/ $id]]

    verifyHttpResponseCode $response

    return $id
  }

  ###########################################################################
  # Environment Variables
  ###########################################################################

  nproc public_listEnvVars { proxy } {
    set response [makeApiCall type public name listEnvVars proxy $proxy]
    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_setEnvVars { json proxy } {
    set response [makeApiCall \
        type public name setEnvVars json $json proxy $proxy]

    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_deleteEnvVar { key proxy } {
    set response [makeApiCall \
        type public name deleteEnvVar key $key proxy $proxy]

    verifyHttpResponseCode $response 204

    return $key
  }

  package provide Chelsea.Apis 1.0
}
