  nproc internal_getVmState { id } {
    set response [makeApiCall type internal name getVmState id $id]
    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    set state [jqRawString $stdOut .state]

    if {![string is alpha -strict $state]} {
      error [appendArgs "invalid state: " $state]
    }

    return $state
  }

