  }

  nproc public_listCommits { proxy {limit ""} {offset ""} } {
    set query [list]

    if {[string length $limit] > 0} then {
      if {![string is integer -strict $limit]} then {
        error [appendArgs "limit must be integer: " $limit]
      }

      lappend query limit $limit
    }

    if {[string length $offset] > 0} then {
      if {![string is integer -strict $offset]} then {
        error [appendArgs "offset must be integer: " $offset]
      }

      lappend query offset $offset
    }

    set response [makeApiCall \
        type public name listCommits proxy $proxy parameters $query]

    verifyHttpResponseCode $response

    set stdOut [getDictionaryValue $response stdOut]

    if {![isValidJson $stdOut]} then {
      error [appendArgs "bad response JSON: " $stdOut]
    }

    return $stdOut
  }

  nproc public_deleteCommit { id proxy } {
    set response [makeApiCall \
        type public name deleteCommit id $id proxy $proxy]

    verifyHttpResponseCode $response 204

    return $id
  }

